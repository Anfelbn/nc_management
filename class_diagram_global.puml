' #####################################################################
' RELATIONS
' #####################################################################

AbstractFiche <|-- Nonconformity
AbstractFiche <|-- CorrectiveAction

' --- Domaine 1 : FNC / FAC ---
Nonconformity   "0..1" -right- "0..*" CorrectiveAction : génère (fnc_id / fac_ids)
CorrectiveAction "1" *-- "0..*" ActionLine : action_line_ids

' --- Domaine 2 : Plans SMI 3 niveaux ---
Nonconformity "0..1" -- "0..*" PlanActionSmi : fnc_id (optionnel)

SmiImprovementPlan "0..1" o-- "0..*" PlanActionSmi : plan_ids / improvement_plan_id
SmiGlobalPlan       "0..1" o-- "0..*" SmiImprovementPlan : improvement_plan_ids / global_plan_id
SmiGlobalPlan       "0..1" o-- "0..*" PlanActionSmi : direct_plan_ids / direct_global_plan_id

' Ancien systeme (legacy, conservé pour compat)
PlanActionSmi "0..1" -- "0..*" PlanActionSmi : global_plan_id / child_plan_ids

' --- Domaine 3 : Gabarits & Révisions ---
DocumentRevision "0..1" -- "0..*" FormTemplate : revision_id
FormTemplate "1" *-- "0..*" FormSection : section_ids
FormSection  "1" *-- "0..*" FormLine    : line_ids

' --- Domaine 4 : Dashboard (lecture RPC, sans persistance) ---
NcDashboard ..> Nonconformity : lit
NcDashboard ..> CorrectiveAction : lit
NcDashboard ..> PlanActionSmi : lit
NcDashboard ..> SmiImprovementPlan : lit

' --- Domaine 5 : Assistants (Wizards) ---

NumberGeneratorWizard "0..*" --> "1"    NcType        : nc_type_id
NumberGeneratorWizard "0..*" --> "0..1" Nonconformity : fnc_id
Nonconformity ..> NumberGeneratorWizard : action_open_number_wizard()

SendFncWizard "0..*" --> "1" Nonconformity : fnc_id
Nonconformity ..> SendFncWizard : action_open_send_wizard()

SendFacWizard "0..*" --> "1" CorrectiveAction : fac_id
CorrectiveAction ..> SendFacWizard : action_open_send_fac_wizard()

SendPlanWizard "0..*" --> "1" PlanActionSmi : plan_id
PlanActionSmi ..> SendPlanWizard : action_open_send_plan_wizard()

PlanNumberWizard "0..*" --> "1" PlanActionSmi : plan_id
PlanActionSmi ..> PlanNumberWizard : action_generate_plan_number()

ConsulterVersionWizard "0..*" --> "1" PlanActionSmi : plan_id
PlanActionSmi ..> ConsulterVersionWizard : action_open_consulter_version_wizard()

ConsulterVersionImprovementWizard "0..*" --> "1" SmiImprovementPlan : improvement_plan_id
SmiImprovementPlan ..> ConsulterVersionImprovementWizard : action_open_consulter_version_wizard()

PlanEfficaciteWizard "1" *-- "0..*" PlanEfficaciteLine : line_ids
PlanEfficaciteWizard "0..*" --> "1" PlanActionSmi : plan_id
PlanActionSmi ..> PlanEfficaciteWizard : action_open_analyser_wizard()

ConsolidateWizard "1" *-- "0..*" ConsolidateWizardLine : line_ids
ConsolidateWizard "0..*" --> "1" PlanActionSmi : global_plan_id (is_global=True)
ConsolidateWizardLine "0..*" --> "1" SmiImprovementPlan : improvement_plan_id
PlanActionSmi ..> ConsolidateWizard : action_consolider_tous() <<legacy>>

ConsolidateImprovementWizard "1" *-- "0..*" ConsolidateImprovementWizardLine : line_ids
ConsolidateImprovementWizard "0..*" --> "1" SmiImprovementPlan : improvement_plan_id
ConsolidateImprovementWizardLine "0..*" --> "1" PlanActionSmi : plan_id
SmiImprovementPlan ..> ConsolidateImprovementWizard : action_consolider()

ReplyWizard ..> Nonconformity : action_reply()\n(record_model générique)
ReplyWizard ..> CorrectiveAction : action_reply()\n(record_model générique)
ReplyWizard ..> PlanActionSmi : action_reply()\n(record_model générique)

ExportPlanWizard ..> PlanActionSmi : action_export()\n(search([]))
ExportSmiAnalysisWizard ..> NcDashboard : action_export()\n(get_plan_smi_stats())

@enduml
