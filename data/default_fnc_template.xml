    <field name="template_id" ref="form_template_fnc_default"/>
    <field name="name">En-tête</field>
    <field name="sequence">10</field>
    <field name="is_active" eval="True"/>
    <field name="show_title" eval="False"/>
    <field name="section_layout">standard</field>
</record>
<record id="line_fnc_a1" model="nc_management.form_line">
    <field name="section_id" ref="sec_fnc_a_entete"/>
    <field name="sequence">10</field>
    <field name="line_type">row</field>
    <field name="col1_field">direction_id</field>
    <field name="col1_label">Emetteur Direction</field>
    <field name="col2_field">date</field>
    <field name="col2_label">Date</field>
</record>
<record id="line_fnc_a2" model="nc_management.form_line">
    <field name="section_id" ref="sec_fnc_a_entete"/>
    <field name="sequence">20</field>
    <field name="line_type">row</field>
    <field name="col1_field">sce_dpt_computed</field>
    <field name="col1_label">Sce / DPT</field>
    <field name="col2_field">name</field>
