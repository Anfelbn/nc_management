<!-- ═══════════════════════════════════════════════
     GABARIT FNC — format initial (réplique exacte)
     ═══════════════════════════════════════════════ -->
<record id="form_template_fnc_default" model="nc_management.form_template">
    <field name="name">FNC — Révision 03 (format initial)</field>
    <field name="doc_type">fnc</field>
    <field name="is_active" eval="True"/>
    <field name="revision_id" ref="rev_fnc_03"/>
</record>

