<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- Cron désactivé : la création du Plan d'Amélioration se fait
         désormais via le bouton "Clôturer et créer le suivant" -->
    <record id="cron_auto_create_global_plan" model="ir.cron">
        <field name="name">Création Plan d'Amélioration SMI (désactivé)</field>
        <field name="model_id" ref="model_nc_management_plan_action_smi"/>
        <field name="state">code</field>
        <field name="code">model._auto_create_global_plan()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="False"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

</data>
</odoo>
