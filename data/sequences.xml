<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <record id="seq_nonconformity" model="ir.sequence">
        <field name="name">FNC Sequence</field>
        <field name="code">nc_management.nonconformity</field>
        <field name="prefix">FNC-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_corrective_action" model="ir.sequence">
        <field name="name">FAC Sequence</field>
        <field name="code">nc_management.corrective_action</field>
        <field name="prefix">FAC-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_plan_action_smi" model="ir.sequence">
        <field name="name">Plan Action SMI</field>
        <field name="code">nc_management.plan_action_smi</field>
        <field name="prefix">SMI-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Séquence Niveau 1 : Plans d'Action individuels (nouveau système) -->
    <record id="seq_smi_action_plan" model="ir.sequence">
        <field name="name">SMI Plan d'Action (niveau 1)</field>
        <field name="code">nc_management.smi_action_plan</field>
        <field name="prefix">SMI/PLAN/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">True</field>
    </record>

    <!-- Séquence Niveau 2 : Plans d'Amélioration par direction -->
    <record id="seq_smi_improvement_plan" model="ir.sequence">
        <field name="name">SMI Plan d'Amélioration (niveau 2)</field>
        <field name="code">nc_management.smi_improvement_plan</field>
        <field name="prefix">SMI/PAA/%(year)s/</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">True</field>
    </record>

</data>
</odoo>
