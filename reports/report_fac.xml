<odoo>
<data>

    <report
        id="action_report_fac"
        model="nc_management.corrective_action"
        string="Fiche d'Action Corrective"
        report_type="qweb-pdf"
        name="nc_management.report_fac_template"
        file="nc_management.report_fac_template"
        attachment_use="False"
        menu="True"
    />

    <template id="report_fac_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    @page {
                        margin: 10mm;
                        size: A4;
                    }
                    .page {
                        width: 100%;
                        margin: 0 !important;
                        padding: 0 !important;
                        font-family: Arial, sans-serif;
                        font-weight: bold;
                        font-size: 11px;
                    }
                    table {
                        width: 100%;
                        border-collapse: collapse;
                        table-layout: fixed;
                        border: 1px solid black;
                        margin-bottom: -1px; /* Évite les doubles bordures entre tables */
                    }
                    td {
                        border: 1px solid black;
                        padding: 4px;
                        word-wrap: break-word;
                    }
                    .bg-blue {
                        background-color: #d9e1f2;
                    }
                    .text-center { text-align: center; }
                    .v-middle { vertical-align: middle; }
                </style>

                <t t-foreach="docs" t-as="doc">
                    <div class="page" style="page-break-after: always;">

                        <table>
                            <tr style="height: 60px;">
                                <td rowspan="3" style="width:20%;" class="text-center v-middle">
                                    <img t-if="env.user.company_id.logo"
                                         t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')"
                                         style="max-width:130px; max-height:70px;"/>
                                </td>
                                <td rowspan="2" class="text-center v-middle">
                                    <span style="font-size:13px;">شركة أسمنت عين الكبيرة</span><br/>
                                    <span>SOCIETE DES CIMENTS DE AIN EL KEBIRA</span><br/>
                                    <span>CEMENT COMPANY OF AIN EL KEBIRA</span>
                                </td>
                                <td style="width:25%;" class="v-middle">
                                    <span>Référence : FAC 003/700</span>
                                </td>
                            </tr>
                            <tr style="height: 30px;">
                                <td class="v-middle">
                                    <span>Révision N° : 02</span>
                                </td>
                            </tr>
                            <tr style="height: 45px;">
                                <td class="bg-blue text-center v-middle">
                                    <i><span style="font-size: 14px;">FICHE D'ACTION CORRECTIVE</span></i><br/>
                                    <i><span>CORRECTIVE ACTION SHEET</span></i>
                                </td>
                                <td class="v-middle">
                                    <span>Date de révision : 30/01/2025</span>
                                </td>
                            </tr>
                        </table>

                        <table>
                            <tr>
                                <td style="width:35%;"><span>Direction : </span> <t t-esc="doc.direction_id.name"/></td>
                                <td style="width:30%;"><span>Date : </span> <t t-esc="doc.date"/></td>
                                <td style="width:35%;"><span>N°FAC : </span> <t t-esc="doc.name"/></td>
                            </tr>
                            <tr>
                                <td style="width:50%;"><span>N°FNC ou autre document : </span> <t t-esc="doc.fnc_id.name"/></td>
                                <td colspan="2"><span>Date : </span> <t t-esc="doc.date_fnc"/></td>
                            </tr>
                            <tr>
                                <td colspan="3" class="bg-blue">1- Rappel de la Non-Conformité</td>
                            </tr>
                            <tr>
                                <td colspan="3" style="height:80px; vertical-align:top;">
                                    <t t-esc="doc.rappel_nc"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3" class="bg-blue">2- Analyse des causes de la non-conformité</td>
                            </tr>
                            <tr>
                                <td colspan="3" style="height:80px; vertical-align:top;">
                                    <t t-esc="doc.analyse_causes"/>
                                </td>
                            </tr>
                        </table>

                        <table>
                            <tr>
                                <td style="width:50%;"><span>Responsable : </span> <t t-esc="doc.responsable_analyse_id.name"/></td>
                                <td style="width:25%;"><span>Date : <t t-esc="doc.date_analyse"/></span></td>
                                <td style="width:25%;"><span>Visa : <t t-esc="doc.visa_analyse"/></span></td>
                            </tr>
                        </table>

                        <table>
                            <tr>
                                <td colspan="4" class="bg-blue">3- Action (s) décidée :</td>
                            </tr>
                            <tr class="text-center">
                                <td style="width:35%;">Action (s)</td>
                                <td style="width:15%;">Date prévue</td>
                                <td style="width:15%;">Date de réalisation</td>
                                <td style="width:35%;">Responsable de l'action</td>
                            </tr>
                            <t t-foreach="doc.action_line_ids" t-as="line">
                                <tr style="height:25px;">
                                    <td><t t-esc="line.action_description"/></td>
                                    <td class="text-center"><t t-esc="line.date_prevue"/></td>
                                    <td class="text-center"><t t-esc="line.date_realisation"/></td>
                                    <td><t t-esc="line.responsable_id.name"/></td>
                                </tr>
                            </t>
                            <!-- Lignes vides pour compléter si nécessaire -->
                            <t t-if="len(doc.action_line_ids) == 0">
                                <tr style="height:25px;"><td>1-</td><td></td><td></td><td></td></tr>
                                <tr style="height:25px;"><td>2-</td><td></td><td></td><td></td></tr>
                            </t>
                            <t t-if="len(doc.action_line_ids) == 1">
                                <tr style="height:25px;"><td>2-</td><td></td><td></td><td></td></tr>
                            </t>
                        </table>

                        <table>
                            <tr>
                                <td style="width:50%;"><span>Responsable : <t t-esc="doc.responsable_actions_id.name"/></span></td>
                                <td style="width:25%;"><span>Date : <t t-esc="doc.date_actions"/></span></td>
                                <td style="width:25%;"><span>Visa : <t t-esc="doc.visa_actions"/></span></td>
                            </tr>
                            <tr>
                                <td style="width:50%;">
                                    <span>Action(s) efficace(s)</span><br/>
                                    <span><t t-if="doc.actions_efficaces == 'oui'">&#9745;</t><t t-else="">&#9744;</t> Oui</span><br/>
                                    <span><t t-if="doc.actions_efficaces == 'non'">&#9745;</t><t t-else="">&#9744;</t> Non</span>
                                </td>
                                <td colspan="2" style="vertical-align:top;">
                                    <span>Responsable : <t t-esc="doc.responsable_efficacite_id.name"/></span>
                                </td>
                            </tr>
                        </table>

                        <table>
                            <tr><td colspan="3" class="bg-blue">4- Approbation Responsable QSE :</td></tr>
                            <tr>
                                <td style="width:35%;">Nom : <t t-esc="doc.qse_nom_id.name"/></td>
                                <td style="width:30%;">Date : <t t-esc="doc.qse_date"/></td>
                                <td style="width:35%;">Visa : <t t-esc="doc.qse_visa"/></td>
                            </tr>
                            <tr><td colspan="3" class="bg-blue">5- Vérification de (s) de(s) action(s) effectuée(s) :</td></tr>
                            <tr>
                                <td colspan="3" style="height:60px; vertical-align:top;">
                                    <span>- Vérification de l'efficacité de l'action :</span><br/>
                                    <t t-esc="doc.verification_efficacite"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3">
                                    <span>- Extension possible de l'action : </span>
                                    <span><t t-if="doc.extension_possible == 'non'">&#9745;</t><t t-else="">&#9744;</t> Non</span> 
                                    <span style="margin-left:20px;"><t t-if="doc.extension_possible == 'oui'">&#9745;</t><t t-else="">&#9744;</t> Oui</span>
                                </td>
                            </tr>
                        </table>

                        <table>
                            <tr>
                                <td style="width:50%; height:40px;"><span>Clôturée par : <t t-esc="doc.cloture_par_id.name"/></span></td>
                                <td style="width:25%;"><span>Date : <t t-esc="doc.date_cloture"/></span></td>
                                <td style="width:25%;"><span>Visa : <t t-esc="doc.visa_cloture"/></span></td>
                            </tr>
                        </table>

                        <div style="text-align:right; font-size:10px; padding-top: 5px;">
                            <span>FAC 003/700</span>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</data>
</odoo>