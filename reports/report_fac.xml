<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <report
        id="action_report_fac"
        model="nc_management.corrective_action"
        string="Fiche d'Action Corrective"
        report_type="qweb-pdf"
        name="nc_management.report_fac_template"
        file="nc_management.report_fac_template"
        attachment_use="False"
        menu="True"
    />

    <template id="report_fac_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    @page { size: A4 portrait; margin: 0mm; }
                    body { margin: 0; padding: 0; }
                    .page {
                        width: 100%; min-height: 281mm;
                        font-family: Arial, sans-serif; font-weight: bold; font-size: 11px;
                        position: relative; padding: 8mm 4mm 5mm 4mm; box-sizing: border-box;
                    }
                    table { width: 100%; border-collapse: collapse; table-layout: fixed; border: 2px solid black; }
                    td { border: 2px solid black; padding: 4px 6px; word-wrap: break-word; vertical-align: middle; font-size: 11px; }
                    .bg-blue { background-color: #d6e3f8; text-align: center; font-weight: bold; }
                    .section-title { background-color: #d6e3f8; font-weight: bold; text-align: left; padding: 5px 6px; height: 25px; }
                    .header-cell { text-align: center; vertical-align: middle; }
                    .checkbox { font-size: 13px; display: inline; }
                    .cell-sm { height: 32px; }
                    .cell-md { height: 80px; vertical-align: top; padding: 6px; }
                    .cell-lg { height: 100px; vertical-align: top; padding: 6px; }
                    .cell-xl { height: 180px; vertical-align: top; padding: 6px; }
                    .footer-ref { text-align: right; font-size: 12px; font-weight: bold; margin-top: 18mm; padding-right: 5px; }
                </style>

                <t t-foreach="docs" t-as="doc">
                    <div class="page">

                        <!-- ===== EN-TÊTE FIXE ===== -->
                        <t t-set="valable_rev" t-value="env['nc_management.document_revision'].search(
                            [('doc_type','=','fac'),('etat','=','valable')], limit=1)"/>
                        <table style="margin-bottom:6px;">
                            <tr style="height:70px;">
                                <td rowspan="3" style="width:18%;text-align:center;vertical-align:middle;">
                                    <img t-if="env.user.company_id.logo"
                                         t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')"
                                         style="max-width:110px;max-height:55px;"/>
                                </td>
                                <td rowspan="2" class="header-cell" style="width:52%;">
                                    <div style="font-size:13px;margin-bottom:2px;">شركة الإسمنت عين الكبيرة</div>
                                    <div style="font-size:11px;">SOCIETE DES CIMENTS DE AIN EL KEBIRA</div>
                                    <div style="font-size:10px;">CEMENT COMPANY OF AIN EL KEBIRA</div>
                                </td>
                                <td style="width:30%;vertical-align:middle;">
                                    <span>Référence : <t t-if="valable_rev and valable_rev.reference" t-esc="valable_rev.reference"/><t t-else="">FAC 003/700</t></span>
                                </td>
                            </tr>
                            <tr style="height:25px;">
                                <td style="vertical-align:middle;">
                                    <span>Révision N° : <t t-if="valable_rev" t-esc="'%02d' % valable_rev.revision_number"/><t t-else="">00</t></span>
                                </td>
                            </tr>
                            <tr style="height:45px;">
                                <td class="bg-blue" style="text-align:center;vertical-align:middle;">
                                    <div style="font-size:12px;font-style:italic;">FICHE D'ACTION CORRECTIVE</div>
                                    <div style="font-size:10px;font-style:italic;">CORRECTIVE ACTION SHEET</div>
                                </td>
                                <td style="vertical-align:middle;">
                                    <span>Date de révision : <t t-if="valable_rev" t-esc="valable_rev.revision_date"/><t t-else="">/</t></span>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== CORPS DYNAMIQUE ===== -->
                        <t t-set="tpl" t-value="env['nc_management.form_template'].search(
                            [('doc_type','=','fac'),('is_active','=',True)], limit=1)"/>

                        <t t-if="tpl">
                            <t t-foreach="tpl.section_ids.filtered(lambda s: s.is_active).sorted(lambda s: s.sequence)" t-as="sec">

                                <!-- == TABLEAU ACTIONS (layout spécial FAC) == -->
                                <t t-if="sec.section_layout == 'action_lines'">
                                    <table style="margin-bottom:6px;">
                                        <tr><td colspan="4" class="section-title"><t t-esc="sec.name"/></td></tr>
                                        <tr style="height:25px;text-align:center;">
                                            <td style="width:35%;">Action(s)</td>
                                            <td style="width:15%;">Date prévue</td>
                                            <td style="width:15%;">Date de réalisation</td>
                                            <td style="width:35%;">Responsable de l'action</td>
                                        </tr>
                                        <t t-foreach="doc.action_line_ids" t-as="al">
                                            <tr class="cell-sm">
                                                <td><t t-esc="al.action_description or ''"/></td>
                                                <td style="text-align:center;"><t t-esc="al.date_prevue or ''"/></td>
                                                <td style="text-align:center;"><t t-esc="al.date_realisation or ''"/></td>
                                                <td><t t-esc="al.responsable_id.name if al.responsable_id else ''"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="len(doc.action_line_ids) == 0">
                                            <tr class="cell-sm"><td>1-</td><td></td><td></td><td></td></tr>
                                            <tr class="cell-sm"><td>2-</td><td></td><td></td><td></td></tr>
                                        </t>
                                        <t t-elif="len(doc.action_line_ids) == 1">
                                            <tr class="cell-sm"><td>2-</td><td></td><td></td><td></td></tr>
                                        </t>
                                    </table>
                                </t>
                                <t t-else="">
                                    <table style="margin-bottom:6px;">
                                        <t t-if="sec.show_title">
                                            <tr><td colspan="3" class="section-title"><t t-esc="sec.name"/></td></tr>
                                        </t>

                                        <t t-foreach="sec.line_ids.filtered(lambda l: l.is_active).sorted(lambda l: l.sequence)" t-as="line">

                                            <!-- TEXTAREA -->
                                            <t t-if="line.line_type == 'textarea'">
                                                <t t-if="line.ta_label">
                                                    <tr><td colspan="3" style="padding:6px;">
                                                        <div style="margin-bottom:3px;font-weight:bold;"><t t-esc="line.ta_label"/></div>
                                                        <div style="min-height:40px;">
                                                            <t t-if="line.ta_field"><t t-esc="doc[line.ta_field] or ''"/></t>
                                                        </div>
                                                    </td></tr>
                                                </t>
                                                <t t-else="">
                                                    <tr>
                                                        <td colspan="3" t-attf-class="cell-#{line.ta_height or 'md'}">
                                                            <t t-if="line.ta_field"><t t-esc="doc[line.ta_field] or ''"/></t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                            <t t-elif="line.line_type == 'row'">
                                                <tr class="cell-sm">
                                                    <t t-if="line.col1_field">
                                                        <td t-attf-style="width:#{34 if line.nb_cols == 3 else (50 if line.nb_cols == 2 else 100)}%;">
                                                            <t t-if="line.render_type_col1 == 'boolean'">
                                                                <t t-if="doc[line.col1_field]"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> <t t-esc="line.col1_label or ''"/></span>
                                                            </t>
                                                            <t t-else="">
                                                                <t t-if="line.col1_label"><span><t t-esc="line.col1_label"/> : </span></t>
                                                                <t t-if="line.render_type_col1 == 'many2one'"><t t-esc="doc[line.col1_field].name if doc[line.col1_field] else ''"/></t>
                                                                <t t-else=""><t t-esc="doc[line.col1_field] or ''"/></t>
                                                            </t>
                                                        </td>
                                                    </t>
                                                    <t t-if="line.col2_field">
                                                        <td t-attf-style="width:#{33 if line.nb_cols == 3 else 50}%;">
                                                            <t t-if="line.render_type_col2 == 'boolean'">
                                                                <t t-if="doc[line.col2_field]"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> <t t-esc="line.col2_label or ''"/></span>
                                                            </t>
                                                            <t t-else="">
                                                                <t t-if="line.col2_label"><span><t t-esc="line.col2_label"/> : </span></t>
                                                                <t t-if="line.render_type_col2 == 'many2one'"><t t-esc="doc[line.col2_field].name if doc[line.col2_field] else ''"/></t>
                                                                <t t-else=""><t t-esc="doc[line.col2_field] or ''"/></t>
                                                            </t>
                                                        </td>
                                                    </t>
                                                    <t t-if="line.col3_field">
                                                        <td style="width:33%;">
                                                            <t t-if="line.render_type_col3 == 'boolean'">
                                                                <t t-if="doc[line.col3_field]"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> <t t-esc="line.col3_label or ''"/></span>
                                                            </t>
                                                            <t t-else="">
                                                                <t t-if="line.col3_label"><span><t t-esc="line.col3_label"/> : </span></t>
                                                                <t t-if="line.render_type_col3 == 'many2one'"><t t-esc="doc[line.col3_field].name if doc[line.col3_field] else ''"/></t>
                                                                <t t-else=""><t t-esc="doc[line.col3_field] or ''"/></t>
                                                            </t>
                                                        </td>
                                                    </t>
                                                </tr>
                                            </t>
                                            <t t-elif="line.line_type == 'checkbox'">
                                                <tr class="cell-sm">
                                                    <td colspan="3">
                                                        <t t-if="line.cb_field">
                                                            <t t-if="line.render_type_cb == 'selection_yes_no'">
                                                                <span style="font-weight:bold;margin-right:8px;"><t t-esc="line.cb_label or ''"/></span>
                                                                <t t-if="doc[line.cb_field] == 'oui'"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> Oui</span>
                                                                <span style="margin-left:15px;">
                                                                    <t t-if="doc[line.cb_field] == 'non'"><span class="checkbox">&#9745;</span></t>
                                                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                    <span> Non</span>
                                                                </span>
                                                            </t>
                                                            <t t-elif="line.render_type_cb == 'selection_non_oui'">
                                                                <span style="margin-right:8px;"><t t-esc="line.cb_label or ''"/></span>
                                                                <t t-if="doc[line.cb_field] == 'non'"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> Non</span>
                                                                <span style="margin-left:20px;">
                                                                    <t t-if="doc[line.cb_field] == 'oui'"><span class="checkbox">&#9745;</span></t>
                                                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                    <span> Oui</span>
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <t t-if="doc[line.cb_field]"><span class="checkbox">&#9745;</span></t>
                                                                <t t-else=""><span class="checkbox">&#9744;</span></t>
                                                                <span> <t t-esc="line.cb_label or ''"/></span>
                                                            </t>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-elif="line.line_type == 'custom_text'">
                                                <tr class="cell-sm">
                                                    <td colspan="3"><t t-esc="line.custom_text or ''"/></td>
                                                </tr>
                                            </t>
                                            <t t-elif="line.line_type == 'separator'">
                                                <tr style="height:8px;">
                                                    <td colspan="3" style="border-left:none;border-right:none;border-bottom:none;"></td>
                                                </tr>
                                            </t>

                                        </t><!-- /foreach lines -->
                                    </table>
                                </t>

                            </t><!-- /foreach sections -->
                        </t>

                        <t t-else="">
                            <p style="color:red;padding:10px;text-align:center;">
                                Aucun gabarit FAC actif. Allez dans Révisions de documents &gt; Gabarits FNC/FAC.
                            </p>
                        </t>

                        <!-- ===== PIED DE PAGE DYNAMIQUE ===== -->
                        <div class="footer-ref">
                            <span><t t-if="valable_rev and valable_rev.reference" t-esc="valable_rev.reference"/><t t-else="">FAC 003/700</t></span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</data>
</odoo>
