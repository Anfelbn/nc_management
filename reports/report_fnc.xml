<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <report
        id="action_report_fnc"
        model="nc_management.nonconformity"
        string="Fiche Non-Conformité"
        report_type="qweb-pdf"
        name="nc_management.report_fnc_template"
        file="nc_management.report_fnc_template"
        attachment_use="False"
        menu="True"
    />

    <template id="report_fnc_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    @page {
                        size: A4 portrait;
                        margin: 0mm;
                    }
                    body {
                        margin: 0;
                        padding: 0;
                    }
                    .page {
                        width: 100%;
                        min-height: 281mm;
                        font-family: Arial, sans-serif;
                        font-weight: bold;
                        font-size: 11px;
                        position: relative;
                        padding: 8mm 4mm 5mm 4mm;
                        box-sizing: border-box;
                    }
                    table {
                        width: 100%;
                        border-collapse: collapse;
                        table-layout: fixed;
                        border: 2px solid black;
                    }
                    td {
                        border: 2px solid black;
                        padding: 4px 6px;
                        word-wrap: break-word;
                        vertical-align: middle;
                        font-size: 11px;
                    }
                    .bg-blue {
                        background-color: #d6e3f8;
                        text-align: center;
                        font-weight: bold;
                    }
                    .section-title {
                        background-color: #d6e3f8;
                        font-weight: bold;
                        text-align: left;
                        padding: 5px 6px;
                        height: 25px;
                    }
                    .header-cell {
                        text-align: center;
                        vertical-align: middle;
                    }
                    .checkbox {
                        font-size: 13px;
                        display: inline;
                    }
                    .cell-sm { height: 32px; }
                    .cell-md { height: 100px; vertical-align: top; padding: 6px; }
                    .cell-lg { height: 140px; vertical-align: top; padding: 6px; }
                    /* TYPE NC PLUS HAUT - 110px ÷ 5 cases = 22px chacune */
                    .cell-type { 
                        height: 110px; 
                        vertical-align: top; 
                        padding: 0;
                    }
                    .type-row {
                        border-bottom: 2px solid #666;
                        height: 22px;       
                        line-height: 22px;
                        padding: 0 6px;
                        box-sizing: border-box;
                        overflow: hidden;
                    }
                    .type-row:last-child {
                        border-bottom: none;
                    }
                    .footer-ref {
                        text-align: right;
                        font-size: 12px;
                        font-weight: bold;
                        margin-top: 18mm;
                        padding-right: 5px;
                    }
                </style>

                <t t-foreach="docs" t-as="doc">
                    <div class="page">

                        <!-- ===== HEADER ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr style="height: 70px;">
                                <td rowspan="3" style="width:18%; text-align:center; vertical-align:middle;">
                                    <img t-if="env.user.company_id.logo"
                                         t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')"
                                         style="max-width:110px; max-height:55px;"/>
                                </td>
                                <td rowspan="2" class="header-cell" style="width:52%;">
                                    <div style="font-size:13px; margin-bottom:2px;">شركة الإسمنت عين الكبيرة</div>
                                    <div style="font-size:11px;">SOCIETE DES CIMENTS DE AIN EL KEBIRA</div>
                                    <div style="font-size:10px;">CEMENT COMPANY OF AIN EL KEBIRA</div>
                                </td>
                                <td style="width:30%; vertical-align:middle;">
                                    <span>Référence : FNC 002/700</span>
                                </td>
                            </tr>
                            <tr style="height: 25px;">
                                <td style="vertical-align:middle;">
                                    <span>Révision N° : 03</span>
                                </td>
                            </tr>
                            <tr style="height: 45px;">
                                <td class="bg-blue" style="text-align:center; vertical-align:middle;">
                                    <div style="font-size:12px; font-style:italic;">FICHE DE NON-CONFORMITE</div>
                                    <div style="font-size:10px; font-style:italic;">NON-CONFORMITY SHEET</div>
                                </td>
                                <td style="vertical-align:middle;">
                                    <span>Date de révision : 03/02/2025</span>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== INFOS GÉNÉRALES ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr class="cell-sm">
                                <td style="width:50%;">
                                    <span>Emetteur Direction : </span>
                                    <t t-esc="doc.direction_id.name or ''"/>
                                </td>
                                <td colspan="2" style="width:50%;">
                                    <span>Date : </span>
                                    <t t-esc="doc.date or ''"/>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td>
                                    <span>Sce /DPT : </span>
                                    <t t-esc="doc.service_dpt or ''"/>
                                </td>
                                <td colspan="2">
                                    <span>N° FNC : </span>
                                    <t t-esc="doc.name or ''"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== TYPE DE NON-CONFORMITÉ (PLUS HAUT) ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr>
                                <td colspan="2" class="section-title">Type de Non-Conformité</td>
                            </tr>
                            <tr>
                                <td class="cell-type" style="width:50%;">
                                    <div class="type-row">
                                        <t t-if="doc.type_nc_produit"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>NC Produit</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_reclamation"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Réclamation clients/PI</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_sst"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>SST Accident</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_environnement"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Environnement</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_travaux"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Travaux</span>
                                    </div>
                                </td>
                                <td class="cell-type" style="width:50%;">
                                    <div class="type-row">
                                        <t t-if="doc.type_audit"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Audit interne/Externe</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_achat"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Achat</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_reception"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Réception</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_dysfonctionnement"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Dysfonctionnement</span>
                                    </div>
                                    <div class="type-row">
                                        <t t-if="doc.type_autre"><span class="checkbox">&#9745;</span></t>
                                        <t t-else=""><span class="checkbox">&#9744;</span></t>
                                        <span>Autre (préciser) : <t t-esc="doc.type_autre_preciser or ''"/></span>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== 1- DESCRIPTION (GRAND) ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr>
                                <td colspan="3" class="section-title">1- Description de la non-conformité :</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="cell-lg">
                                    <t t-esc="doc.description or ''"/>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td style="width:33%;">
                                    <span>Nom de la personne qui signale :</span><br/>
                                    <t t-esc="doc.signale_par_id.name or ''"/>
                                </td>
                                <td style="width:33%;">
                                    <span>Date :</span><br/>
                                    <t t-esc="doc.date_signalement or ''"/>
                                </td>
                                <td style="width:34%;">
                                    <span>Fonction et visa :</span><br/>
                                    <t t-esc="doc.fonction_visa or ''"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== TRAITEMENT ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr>
                                <td colspan="3" class="section-title">Traitement :</td>
                            </tr>
                            <tr class="cell-sm">
                                <td style="width:33%;">
                                    <t t-if="doc.trait_reprise"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Reprise pour mise en conformité</span>
                                </td>
                                <td style="width:33%;">
                                    <t t-if="doc.trait_declassement"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Déclassement pour autre utilisation</span>
                                </td>
                                <td style="width:34%;">
                                    <t t-if="doc.trait_retour_fourn"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Retour au fournisseur</span>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td>
                                    <t t-if="doc.trait_recyclage"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Recyclage</span>
                                </td>
                                <td>
                                    <t t-if="doc.trait_reparation"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Réparation</span>
                                </td>
                                <td>
                                    <t t-if="doc.trait_autre"><span class="checkbox">&#9745;</span></t>
                                    <t t-else=""><span class="checkbox">&#9744;</span></t>
                                    <span>Autre ;.......</span>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== 2- ACTION IMMÉDIATE (GRAND) ===== -->
                        <table style="margin-bottom: 6px;">
                            <tr>
                                <td colspan="2" class="section-title">2- Action immédiate :</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="cell-md">
                                    <t t-esc="doc.action_immediate or ''"/>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td style="width:50%;">
                                    <span>Réalisé par :</span>
                                    <t t-esc="doc.realise_par_id.name or ''"/>
                                </td>
                                <td style="width:50%;">
                                    <span>Date :</span>
                                    <t t-esc="doc.date_realisation or ''"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== 3- ANALYSE DES CAUSES (GRAND) ===== -->
                        <table style="margin-bottom: 0px;">
                            <tr>
                                <td colspan="3" class="section-title">3- Analyse des causes</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="cell-md">
                                    <t t-esc="doc.analyse_causes or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3" style="padding:6px;">
                                    <div style="margin-bottom:3px; font-weight:bold;">-Impact : coût, incidence, risque :</div>
                                    <div style="min-height: 50px;">
                                        <t t-esc="doc.impact or ''"/>
                                    </div>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td style="width:50%;">
                                    <span>N° Fiche d'action :</span>
                                    <t t-esc="doc.fac_reference or ''"/>
                                </td>
                                <td colspan="2" style="width:50%;">
                                    <span>Responsable de l'action(s) :</span>
                                    <t t-esc="doc.responsable_action_id.name or ''"/>
                                </td>
                            </tr>
                            <tr class="cell-sm">
                                <td>
                                    <span>Le supérieur hiérarchique :</span>
                                    <t t-esc="doc.superieur_id.name or ''"/>
                                </td>
                                <td>
                                    <span>Date :</span>
                                    <t t-esc="doc.date_validation or ''"/>
                                </td>
                                <td>
                                    <span>Signature :</span>
                                    <t t-esc="doc.signature or ''"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ===== FNC 002/700 À 6mm SOUS LE DERNIER TABLEAU ===== -->
                        <div class="footer-ref">
                            <span>FNC 002/700</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</data>
</odoo>