<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <report
        id="action_report_revision"
        model="nc_management.document_revision"
        string="Révision de Document"
        report_type="qweb-pdf"
        name="nc_management.report_revision_template"
        file="nc_management.report_revision_template"
        attachment_use="False"
        menu="True"
    />

    <template id="report_revision_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="rev">
                    <t t-if="rev.doc_type == 'fnc'">
                        <t t-call="nc_management.report_fnc_revision_content">
                            <t t-set="doc_rev" t-value="rev"/>
                        </t>
                    </t>
                    <t t-if="rev.doc_type == 'fac'">
                        <t t-call="nc_management.report_fac_revision_content">
                            <t t-set="doc_rev" t-value="rev"/>
                        </t>
                    </t>
                    <!-- Force page break between revisions if multiple -->
                    <p style="page-break-after:always;"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_fnc_revision_content">
        <style>
            .page { width: 100%; min-height: 281mm; font-family: Arial, sans-serif; font-weight: bold; font-size: 11px; position: relative; padding: 8mm 4mm 5mm 4mm; box-sizing: border-box; }
            table { width: 100%; border-collapse: collapse; table-layout: fixed; border: 2px solid black; }
            td { border: 2px solid black; padding: 4px 6px; word-wrap: break-word; vertical-align: middle; font-size: 11px; }
            .bg-blue { background-color: #d6e3f8; text-align: center; font-weight: bold; }
            .section-title { background-color: #d6e3f8; font-weight: bold; text-align: left; padding: 5px 6px; height: 25px; }
            .header-cell { text-align: center; vertical-align: middle; }
            .cell-sm { height: 32px; }
            .cell-md { height: 100px; vertical-align: top; padding: 6px; }
            .cell-lg { height: 140px; vertical-align: top; padding: 6px; }
            .cell-type { height: 110px; vertical-align: top; padding: 0; }
            .type-row { border-bottom: 2px solid #666; height: 22px; line-height: 22px; padding: 0 6px; box-sizing: border-box; overflow: hidden; }
            .type-row:last-child { border-bottom: none; }
            .footer-ref { text-align: right; font-size: 12px; font-weight: bold; margin-top: 18mm; padding-right: 5px; }
            .checkbox { font-size: 13px; display: inline; }
        </style>
        <div class="page">
            <!-- HEADER -->
            <table style="margin-bottom: 6px;">
                <tr style="height: 70px;">
                    <td rowspan="3" style="width:18%; text-align:center; vertical-align:middle;">
                        <img t-if="env.user.company_id.logo" t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')" style="max-width:110px; max-height:55px;"/>
                    </td>
                    <td rowspan="2" class="header-cell" style="width:52%;">
                        <div style="font-size:13px; margin-bottom:2px;">شركة الإسمنت عين الكبيرة</div>
                        <div style="font-size:11px;">SOCIETE DES CIMENTS DE AIN EL KEBIRA</div>
                        <div style="font-size:10px;">CEMENT COMPANY OF AIN EL KEBIRA</div>
                    </td>
                    <td style="width:30%; vertical-align:middle;">
                        <span>Référence : <t t-esc="doc_rev.reference or ''"/></span>
                    </td>
                </tr>
                <tr style="height: 25px;">
                    <td style="vertical-align:middle;">
                        <span>Révision N° : <t t-esc="'%02d' % doc_rev.revision_number"/></span>
                    </td>
                </tr>
                <tr style="height: 45px;">
                    <td class="bg-blue" style="text-align:center; vertical-align:middle;">
                        <div style="font-size:12px; font-style:italic;">FICHE DE NON-CONFORMITE</div>
                        <div style="font-size:10px; font-style:italic;">NON-CONFORMITY SHEET</div>
                    </td>
                    <td style="vertical-align:middle;">
                        <span>Date de révision : <t t-esc="doc_rev.revision_date"/></span>
                    </td>
                </tr>
            </table>
            <!-- BLANK FORM -->
            <table style="margin-bottom: 6px;">
                <tr class="cell-sm"><td style="width:50%;">Emetteur Direction :</td><td colspan="2" style="width:50%;">Date :</td></tr>
                <tr class="cell-sm"><td>Sce /DPT :</td><td colspan="2">N° FNC :</td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="2" class="section-title">Type de Non-Conformité</td></tr>
                <tr>
                    <td class="cell-type" style="width:50%;">
                        <div class="type-row"><span class="checkbox">&#9744;</span> NC Produit</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Réclamation clients/PI</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> SST Accident</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Environnement</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Travaux</div>
                    </td>
                    <td class="cell-type" style="width:50%;">
                        <div class="type-row"><span class="checkbox">&#9744;</span> Audit interne/Externe</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Achat</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Réception</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Dysfonctionnement</div>
                        <div class="type-row"><span class="checkbox">&#9744;</span> Autre (préciser) :</div>
                    </td>
                </tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="3" class="section-title">1- Description de la non-conformité :</td></tr>
                <tr><td colspan="3" class="cell-lg"></td></tr>
                <tr class="cell-sm"><td style="width:33%;">Nom de la personne qui signale :</td><td style="width:33%;">Date :</td><td style="width:34%;">Fonction et visa :</td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="3" class="section-title">Traitement :</td></tr>
                <tr class="cell-sm">
                    <td style="width:33%;"><span class="checkbox">&#9744;</span> Reprise pour mise en conformité</td>
                    <td style="width:33%;"><span class="checkbox">&#9744;</span> Déclassement pour autre utilisation</td>
                    <td style="width:34%;"><span class="checkbox">&#9744;</span> Retour au fournisseur</td>
                </tr>
                <tr class="cell-sm">
                    <td><span class="checkbox">&#9744;</span> Recyclage</td>
                    <td><span class="checkbox">&#9744;</span> Réparation</td>
                    <td><span class="checkbox">&#9744;</span> Autre ;.......</td>
                </tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="2" class="section-title">2- Action immédiate :</td></tr>
                <tr><td colspan="2" class="cell-md"></td></tr>
                <tr class="cell-sm"><td style="width:50%;">Réalisé par :</td><td style="width:50%;">Date :</td></tr>
            </table>
            <table style="margin-bottom: 0px;">
                <tr><td colspan="3" class="section-title">3- Analyse des causes</td></tr>
                <tr><td colspan="3" class="cell-md"></td></tr>
                <tr><td colspan="3" style="padding:6px;"><div style="margin-bottom:3px; font-weight:bold;">-Impact : coût, incidence, risque :</div><div style="min-height: 50px;"></div></td></tr>
                <tr class="cell-sm"><td style="width:50%;">N° Fiche d'action :</td><td colspan="2" style="width:50%;">Responsable de l'action(s) :</td></tr>
                <tr class="cell-sm"><td>Le supérieur hiérarchique :</td><td>Date :</td><td>Signature :</td></tr>
            </table>
            <div class="footer-ref"><t t-esc="doc_rev.reference or ''"/></div>
        </div>
    </template>

    <template id="report_fac_revision_content">
        <style>
            .page { width: 100%; min-height: 281mm; font-family: Arial, sans-serif; font-weight: bold; font-size: 11px; position: relative; padding: 8mm 4mm 5mm 4mm; box-sizing: border-box; }
            table { width: 100%; border-collapse: collapse; table-layout: fixed; border: 2px solid black; }
            td { border: 2px solid black; padding: 4px 6px; word-wrap: break-word; vertical-align: middle; font-size: 11px; }
            .bg-blue { background-color: #d6e3f8; text-align: center; font-weight: bold; }
            .section-title { background-color: #d6e3f8; font-weight: bold; text-align: left; padding: 5px 6px; height: 25px; }
            .header-cell { text-align: center; vertical-align: middle; }
            .cell-sm { height: 32px; }
            .cell-md { height: 80px; vertical-align: top; padding: 6px; }
            .cell-lg { height: 100px; vertical-align: top; padding: 6px; }
            .footer-ref { text-align: right; font-size: 12px; font-weight: bold; margin-top: 18mm; padding-right: 5px; }
            .checkbox { font-size: 13px; display: inline; }
        </style>
        <div class="page">
            <!-- HEADER -->
            <table style="margin-bottom: 6px;">
                <tr style="height: 70px;">
                    <td rowspan="3" style="width:18%; text-align:center; vertical-align:middle;">
                        <img t-if="env.user.company_id.logo" t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')" style="max-width:110px; max-height:55px;"/>
                    </td>
                    <td rowspan="2" class="header-cell" style="width:52%;">
                        <div style="font-size:13px; margin-bottom:2px;">شركة الإسمنت عين الكبيرة</div>
                        <div style="font-size:11px;">SOCIETE DES CIMENTS DE AIN EL KEBIRA</div>
                        <div style="font-size:10px;">CEMENT COMPANY OF AIN EL KEBIRA</div>
                    </td>
                    <td style="width:30%; vertical-align:middle;">
                        <span>Référence : <t t-esc="doc_rev.reference or ''"/></span>
                    </td>
                </tr>
                <tr style="height: 25px;">
                    <td style="vertical-align:middle;">
                        <span>Révision N° : <t t-esc="'%02d' % doc_rev.revision_number"/></span>
                    </td>
                </tr>
                <tr style="height: 45px;">
                    <td class="bg-blue" style="text-align:center; vertical-align:middle;">
                        <div style="font-size:12px; font-style:italic;">FICHE D'ACTION CORRECTIVE</div>
                        <div style="font-size:10px; font-style:italic;">CORRECTIVE ACTION SHEET</div>
                    </td>
                    <td style="vertical-align:middle;">
                        <span>Date de révision : <t t-esc="doc_rev.revision_date"/></span>
                    </td>
                </tr>
            </table>
            <!-- BLANK FORM -->
            <table style="margin-bottom: 6px;">
                <tr class="cell-sm"><td style="width:35%;">Direction :</td><td style="width:30%;">Date :</td><td style="width:35%;">N° FAC :</td></tr>
                <tr class="cell-sm"><td colspan="2">N° FNC ou autre document :</td><td>Date :</td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="3" class="section-title">1- Rappel de la Non-Conformité</td></tr>
                <tr><td colspan="3" class="cell-lg"></td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="3" class="section-title">2- Analyse des causes de la non-conformité</td></tr>
                <tr><td colspan="3" class="cell-lg"></td></tr>
                <tr class="cell-sm"><td style="width:50%;">Responsable :</td><td style="width:25%;">Date :</td><td style="width:25%;">Visa :</td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="4" class="section-title">3- Action (s) décidée :</td></tr>
                <tr style="height: 25px; text-align: center;">
                    <td style="width:35%;">Action (s)</td><td style="width:15%;">Date prévue</td><td style="width:15%;">Date de réalisation</td><td style="width:35%;">Responsable de l'action</td>
                </tr>
                <tr class="cell-sm"><td>1-</td><td></td><td></td><td></td></tr>
                <tr class="cell-sm"><td>2-</td><td></td><td></td><td></td></tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr class="cell-sm"><td style="width:50%;">Responsable :</td><td style="width:25%;">Date :</td><td style="width:25%;">Visa :</td></tr>
                <tr>
                    <td style="width:50%; vertical-align: top; padding: 6px;"><div style="margin-bottom: 4px;"><span>Action(s) efficace(s)</span></div><div><span class="checkbox">&#9744;</span> Oui</div><div><span class="checkbox">&#9744;</span> Non</div></td>
                    <td colspan="2" style="vertical-align: top; padding: 6px;">Responsable :</td>
                </tr>
            </table>
            <table style="margin-bottom: 6px;">
                <tr><td colspan="3" class="section-title">4- Approbation Responsable QSE :</td></tr>
                <tr class="cell-sm"><td style="width:35%;">Nom :</td><td style="width:30%;">Date :</td><td style="width:35%;">Visa :</td></tr>
            </table>
            <table style="margin-bottom: 0px;">
                <tr><td colspan="3" class="section-title">5- Vérification de (s) de(s) action(s) effectuée(s) :</td></tr>
                <tr><td colspan="3" class="cell-md"><div style="margin-bottom: 3px; font-weight: bold;">- Vérification de l'efficacité de l'action :</div></td></tr>
                <tr class="cell-sm"><td colspan="3">- Extension possible de l'action : <span class="checkbox">&#9744;</span> Non <span style="margin-left: 20px;"><span class="checkbox">&#9744;</span> Oui</span></td></tr>
                <tr class="cell-sm"><td style="width:50%;">Clôturée par :</td><td style="width:25%;">Date :</td><td style="width:25%;">Visa :</td></tr>
            </table>
            <div class="footer-ref"><t t-esc="doc_rev.reference or ''"/></div>
        </div>
    </template>

    <!-- ============================================================ -->
    <!--  APERÇU VIERGE — Plan d'Action d'Amélioration SMI (A4 Paysage) -->
    <!-- ============================================================ -->
    <record id="paperformat_plan_smi_revision_landscape" model="report.paperformat">
        <field name="name">Plan SMI Vierge - A4 Paysage</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">6</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <report
        id="action_report_plan_smi_revision"
        model="nc_management.document_revision"
        string="Aperçu Plan d'Action d'Amélioration SMI"
        report_type="qweb-pdf"
        name="nc_management.report_plan_smi_revision_content"
        file="nc_management.report_plan_smi_revision_content"
        attachment_use="False"
        menu="False"
    />

    <record id="action_report_plan_smi_revision" model="ir.actions.report">
        <field name="paperformat_id" ref="paperformat_plan_smi_revision_landscape"/>
    </record>

    <template id="report_plan_smi_revision_content">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="doc_rev">
        <style>
            @page { size: A4 landscape; margin: 6mm 6mm 8mm 6mm; }
            * { box-sizing: border-box; }
            .page-smi { font-family: Arial, sans-serif; font-size: 7.5px; color: #000; width: 100%; }

            .paa-header { width: 100%; border-collapse: collapse; border: 1.5px solid #000; margin-bottom: 3px; font-size: 8px; }
            .paa-header td { border: 1.5px solid #000; padding: 3px 5px; vertical-align: middle; }
            .cell-logo { width: 18%; text-align: center; vertical-align: middle; }
            .cell-company { width: 52%; text-align: center; }
            .cell-ref { width: 30%; font-size: 9px; }
            .company-ar { font-size: 11px; font-weight: bold; direction: rtl; }
            .company-fr { font-size: 9px; font-weight: bold; margin-top: 2px; }
            .company-en { font-size: 8px; color: #333; }
            .cell-title { background-color: #b2dfdb; text-align: center; font-weight: bold; font-size: 9px; padding: 4px 5px; }
            .title-fr { font-size: 10px; font-weight: bold; }
            .title-en { font-size: 8.5px; font-style: italic; }

            .paa-info { width: 40%; border-collapse: collapse; border: 1px solid #000; margin-bottom: 3px; font-size: 7.5px; table-layout: fixed; }
            .paa-info td { border: 1px solid #000; padding: 1.5px 5px; height: 14px; vertical-align: middle; }
            .info-label { font-weight: bold; color: #333; width: 50%; white-space: nowrap; }

            .paa-table { width: 100%; border-collapse: collapse; border: 1.5px solid #000; font-size: 6.8px; table-layout: fixed; }
            .paa-table th { background-color: #00796b; color: #fff; border: 1px solid #004d40; padding: 3px 2px; text-align: center; vertical-align: middle; font-size: 6.5px; font-weight: bold; line-height: 1.2; word-wrap: break-word; }
            .paa-table td { border: 1px solid #9e9e9e; height: 18px; }
            .paa-table tr:nth-child(even) td { background-color: #f5f5f5; }

            .paa-footer { width: 100%; border-collapse: collapse; margin-top: 5px; font-size: 7.5px; }
            .paa-footer td { padding: 2px 4px; vertical-align: middle; }
            .taux-label { font-weight: bold; width: 8%; }
            .taux-bar-wrap { width: 92%; background: #e0e0e0; border-radius: 3px; height: 9px; }
            .taux-val { font-weight: bold; color: #333; width: 6%; text-align: right; }

            .sign-table { width: 40%; border-collapse: collapse; border: 1px solid #000; margin: 6px auto 0 auto; font-size: 7.5px; }
            .sign-table td { border: 1px solid #000; padding: 3px 6px; height: 25px; vertical-align: top; }

            .smi-footer-ref { text-align: right; font-size: 9px; font-weight: bold; margin-top: 4px; }
        </style>
        <div class="page-smi">

            <!-- ===== EN-TÊTE OFFICIEL ===== -->
            <table class="paa-header">
                <tr style="height: 70px;">
                    <td class="cell-logo" rowspan="3">
                        <t t-if="env.user.company_id.logo">
                            <img t-att-src="'data:image/png;base64,' + env.user.company_id.logo.decode('utf-8')"
                                 style="max-width:110px; max-height:55px;"/>
                        </t>
                        <t t-else="">
                            <span style="font-size:9px; font-weight:bold; color:#00796b;">GICA</span>
                        </t>
                    </td>
                    <td class="cell-company" rowspan="2">
                        <div class="company-ar">شـركـة الإسمـنـت عـيـن الكـبيـرة</div>
                        <div class="company-fr">SOCIETE DES CIMENTS DE AIN EL KEBIRA</div>
                        <div class="company-en">CEMENT COMPANY OF AIN EL KEBIRA</div>
                    </td>
                    <td class="cell-ref">Référence : <strong><t t-esc="doc_rev.reference or ''"/></strong></td>
                </tr>
                <tr style="height: 25px;">
                    <td class="cell-ref">Révision N° : <strong><t t-esc="'%02d' % doc_rev.revision_number"/></strong></td>
                </tr>
                <tr style="height: 45px;">
                    <td class="cell-title">
                        <div class="title-fr">Plan d'action d'amélioration SMI</div>
                        <div class="title-en">IMS improvement action plan</div>
                    </td>
                    <td class="cell-ref">Date de révision : <strong><t t-esc="doc_rev.revision_date"/></strong></td>
                </tr>
            </table>

            <!-- ===== INFOS GÉNÉRALES (à compléter) ===== -->
            <table class="paa-info">
                <tr>
                    <td class="info-label">Processus / Direction :</td>
                    <td></td>
                </tr>
                <tr>
                    <td class="info-label">Date de mise à jour :</td>
                    <td></td>
                </tr>
                <tr>
                    <td class="info-label">Référence :</td>
                    <td></td>
                </tr>
            </table>

            <!-- ===== TABLEAU PRINCIPAL (vierge, configurable via Gabarits) ===== -->
            <t t-set="tpl" t-value="env['nc_management.form_template'].search(
                [('doc_type','=','plan_smi'),('is_active','=',True)], limit=1)"/>
            <t t-set="table_sec" t-value="tpl.section_ids.filtered(
                lambda s: s.is_active and s.section_layout == 'blank_table')[:1]"/>
            <t t-set="cols" t-value="table_sec.line_ids.filtered(lambda l: l.is_active).sorted(lambda l: l.sequence)
                if table_sec else env['nc_management.form_line']"/>
            <t t-set="nb_rows" t-value="(table_sec.table_rows or 20) if table_sec else 20"/>
            <table class="paa-table">
                <colgroup>
                    <t t-foreach="cols" t-as="col">
                        <col t-attf-style="width:#{col.col_width or 'auto'};"/>
                    </t>
                </colgroup>
                <thead>
                    <tr>
                        <t t-foreach="cols" t-as="col">
                            <th><t t-esc="col.custom_text or ''"/></th>
                        </t>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="range(nb_rows)" t-as="i">
                        <tr>
                            <t t-foreach="cols" t-as="col">
                                <td></td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>

            <!-- ===== PIED DE PAGE ===== -->
            <table class="paa-footer">
                <tr>
                    <td class="taux-label">TAUX</td>
                    <td><div class="taux-bar-wrap"></div></td>
                    <td class="taux-val"></td>
                </tr>
            </table>

            <!-- Bloc signature -->
            <table class="sign-table">
                <tr>
                    <td style="width:35%; font-weight:bold;">Élaboré par :</td>
                    <td style="width:65%;"></td>
                </tr>
                <tr>
                    <td style="font-weight:bold;">Visa :</td>
                    <td style="height:20px;"></td>
                </tr>
            </table>

            <div class="smi-footer-ref"><t t-esc="doc_rev.reference or ''"/></div>
        </div>
                </t>
            </t>
        </t>
    </template>

</data>
</odoo>
