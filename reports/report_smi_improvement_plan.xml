<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <report
        id="action_report_smi_improvement_plan"
        model="nc_management.smi_improvement_plan"
        string="Plan d'Amélioration"
        report_type="qweb-pdf"
        name="nc_management.report_smi_improvement_plan_template"
        file="nc_management.report_smi_improvement_plan_template"
        attachment_use="False"
        menu="False"
    />

    <template id="report_smi_improvement_plan_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    body { font-family: Arial, sans-serif; font-size: 11px; color: #1a1a1a; }
                    h1   { font-size: 16px; color: #2c3e50; margin-bottom: 4px; }
                    .section-title { font-size: 12px; font-weight: bold; color: #2c3e50;
                                     border-bottom: 1px solid #ccc; margin: 12px 0 6px 0;
                                     padding-bottom: 3px; }
                    table { width: 100%; border-collapse: collapse; font-size: 10px; }
                    th    { background: #2c3e50; color: white; padding: 5px 8px;
                            text-align: left; white-space: nowrap; }
                    td    { padding: 5px 8px; border-bottom: 1px solid #eee; }
                    tr:nth-child(even) td { background: #f7f9fc; }
                    .kv   { width: 48%; vertical-align: top; }
                    .kv td:first-child { font-weight: bold; width: 45%; color: #555; }
                    .footer { font-size: 8px; color: #999; text-align: center;
                              border-top: 1px solid #ccc; margin-top: 14px; padding-top: 4px; }
                </style>
                <t t-foreach="docs" t-as="plan">
                    <div style="padding: 8px;">
                        <h1>Plan d'Action d'Amélioration — <t t-esc="plan.name"/></h1>

                        <div class="section-title">Synthèse</div>
                        <table class="kv">
                            <tr>
                                <td>Direction</td>
                                <td><t t-esc="plan.direction_id.name or '-'"/></td>
                                <td>Date de création</td>
                                <td><t t-esc="plan.date_ouverture or '-'"/></td>
                            </tr>
                            <tr>
                                <td>Plans intégrés</td>
                                <td><t t-esc="plan.nb_plans"/></td>
                                <td>Plans réalisés</td>
                                <td><t t-esc="plan.nb_realises"/></td>
                            </tr>
                            <tr>
                                <td>Taux d'avancement</td>
                                <td><t t-esc="plan.taux_avancement"/>%</td>
                                <td>Taux d'efficacité</td>
                                <td><t t-esc="plan.taux_efficacite"/>%</td>
                            </tr>
                            <tr>
                                <td>État</td>
                                <td><t t-esc="dict([('brouillon','Brouillon'),('soumis','Soumis')]).get(plan.state, plan.state)"/></td>
                                <td>Date d'envoi</td>
                                <td><t t-esc="plan.date_soumission or '-'"/></td>
                            </tr>
                        </table>

                        <div class="section-title">Plans d'Action</div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Référence</th>
                                    <th>Nature</th>
                                    <th>Responsable</th>
                                    <th>Date réalisation</th>
                                    <th>Avancement %</th>
                                    <th>État</th>
                                    <th>Efficacité</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="plan.plan_ids" t-as="p">
                                    <tr>
                                        <td><t t-esc="p.reference or p.name"/></td>
                                        <td><t t-esc="p.nature or '-'"/></td>
                                        <td><t t-esc="p.responsable_id.name or '-'"/></td>
                                        <td><t t-esc="p.date_realisation or '-'"/></td>
                                        <td style="text-align:center;"><t t-esc="p.avancement"/>%</td>
                                        <td><t t-esc="p.etat_avancement or '-'"/></td>
                                        <td><t t-esc="p.efficacite or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <p class="footer">
                            Généré le
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                            — SCAEK Sétif
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</data>
</odoo>
