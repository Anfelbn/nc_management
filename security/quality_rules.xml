<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ── FNC ──────────────────────────────────────────────────── -->

    <record id="rule_fnc_manager" model="ir.rule">
        <field name="name">FNC: Responsable Qualité voit tout</field>
        <field name="model_id" ref="model_nc_management_nonconformity"/>
        <field name="groups" eval="[(4, ref('nc_management.group_responsable_qualite'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_fnc_user" model="ir.rule">
        <field name="name">FNC: Utilisateur voit ses fiches</field>
        <field name="model_id" ref="model_nc_management_nonconformity"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_utilisateur'))]"/>
        <field name="domain_force">['|', '|',
            ('create_uid','=',user.id),
            ('submitted_by_id','=',user.id),
            ('assigned_to_id.user_id','=',user.id)
        ]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ── FAC ──────────────────────────────────────────────────── -->

    <record id="rule_fac_manager" model="ir.rule">
        <field name="name">FAC: Responsable Qualité voit tout</field>
        <field name="model_id" ref="model_nc_management_corrective_action"/>
        <field name="groups" eval="[(4, ref('nc_management.group_responsable_qualite'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_fac_user" model="ir.rule">
        <field name="name">FAC: Utilisateur voit ses FAC</field>
        <field name="model_id" ref="model_nc_management_corrective_action"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_utilisateur'))]"/>
        <field name="domain_force">[('responsable_id','=',user.id)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ── Plan Action SMI ──────────────────────────────────────── -->

    <!-- NC Utilisateur : ses plans uniquement, pas de plans globaux -->
    <record id="rule_plan_smi_utilisateur" model="ir.rule">
        <field name="name">Plan SMI: Utilisateur voit ses plans</field>
        <field name="model_id" ref="model_nc_management_plan_action_smi"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_utilisateur'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id), ('is_global', '=', False)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Responsable Qualité : ses propres plans + tous les plans soumis reçus -->
    <record id="rule_plan_smi_responsable" model="ir.rule">
        <field name="name">Plan SMI: Responsable Qualité voit ses plans + plans reçus</field>
        <field name="model_id" ref="model_nc_management_plan_action_smi"/>
        <field name="groups" eval="[(4, ref('nc_management.group_responsable_qualite'))]"/>
        <field name="domain_force">['|', ('create_uid', '=', user.id), ('sent_to_rmqse', '=', True)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</data>
</odoo>
