<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- Managers see ALL FNC records -->
    <record id="rule_fnc_manager" model="ir.rule">
        <field name="name">FNC: Manager voit tout</field>
        <field name="model_id" ref="model_nc_management_nonconformity"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Users see FNC they created OR are assigned to -->
    <record id="rule_fnc_user" model="ir.rule">
        <field name="name">FNC: User voit ses fiches</field>
        <field name="model_id" ref="model_nc_management_nonconformity"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_user'))]"/>
        <field name="domain_force">['|',
            ('submitted_by_id','=',user.id),
            ('assigned_to_id.user_id','=',user.id)
        ]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers see ALL FAC records -->
    <record id="rule_fac_manager" model="ir.rule">
        <field name="name">FAC: Manager voit tout</field>
        <field name="model_id" ref="model_nc_management_corrective_action"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Users see FAC linked to their FNC (creator or assigned) -->
    <record id="rule_fac_user" model="ir.rule">
        <field name="name">FAC: User voit ses FAC</field>
        <field name="model_id" ref="model_nc_management_corrective_action"/>
        <field name="groups" eval="[(4, ref('nc_management.group_nc_user'))]"/>
        <field name="domain_force">['|',
            ('fnc_id.submitted_by_id','=',user.id),
            ('fnc_id.assigned_to_id.user_id','=',user.id)
        ]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</data>
</odoo>
