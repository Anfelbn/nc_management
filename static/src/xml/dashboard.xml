<?xml version="1.0" encoding="utf-8"?>
<templates>
<t t-name="NcDashboard">
<div class="nc-db">

<div class="nc-inner">
<div class="nc-header">
  <div>
    <div class="nc-brand-sub">CIMENTERIE DE SÉTIF — GICA</div>
    <div class="nc-brand-title">Dashboard RMQSE</div>
  </div>
  <div class="nc-header-right">
    <span style="font-size:10px;font-weight:600;color:#64748b;letter-spacing:.5px;text-transform:uppercase">Période stats</span>
    <div class="period-btn">
      <div class="pb active" data-period="1m">1 mois</div>
      <div class="pb" data-period="6m">6 mois</div>
      <div class="pb" data-period="1y">1 an</div>
    </div>
  </div>
</div>

<div class="nc-section-hdr rmqse">
  <span>Espace RMQSE</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="section-title">Calendrier de réception — FNC &amp; FAC</div>
  <div class="g2">

    <!-- Fiches reçues : FNC regroupées avec leurs FAC dans un seul conteneur -->
    <div class="nc-card" style="max-height:400px;overflow-y:auto">
      <div class="nc-card-title">Fiches reçues</div>
      <div class="nc-card-sub received-sub">Documents reçus aujourd'hui</div>
      <div class="received-list"></div>
    </div>

    <!-- Calendrier indépendant + sélecteur 2-clics -->
    <div style="display:flex;flex-direction:column;gap:8px">
      <div class="nc-card">
        <div class="nc-card-title" style="margin-bottom:8px">Calendrier</div>
        <div class="cal-wrap">
          <div class="cal-header-pick">
            <div class="cal-month-label" style="font-size:13px;font-weight:700;color:#1e293b">Chargement...</div>
            <span style="font-size:11px;color:#94a3b8">▼</span>
          </div>
          <div class="cal-picker" style="display:none;background:#f0f4ff;border:1px solid #c7d7f8;border-radius:8px;padding:8px;margin-bottom:8px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
              <button name="cal_yr_prev" class="cal-btn cal-yr-prev">&#8249;</button>
              <span class="cal-picker-yr" style="font-size:13px;font-weight:700;color:#1e293b">2026</span>
              <button name="cal_yr_next" class="cal-btn cal-yr-next">&#8250;</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px">
              <div class="cal-pm" data-m="0">Jan</div><div class="cal-pm" data-m="1">Fév</div>
              <div class="cal-pm" data-m="2">Mar</div><div class="cal-pm" data-m="3">Avr</div>
              <div class="cal-pm" data-m="4">Mai</div><div class="cal-pm" data-m="5">Jun</div>
              <div class="cal-pm" data-m="6">Jul</div><div class="cal-pm" data-m="7">Aoû</div>
              <div class="cal-pm" data-m="8">Sep</div><div class="cal-pm" data-m="9">Oct</div>
              <div class="cal-pm" data-m="10">Nov</div><div class="cal-pm" data-m="11">Déc</div>
            </div>
          </div>
          <div class="cal-grid">
            <div class="cal-day-name">Lun</div><div class="cal-day-name">Mar</div><div class="cal-day-name">Mer</div><div class="cal-day-name">Jeu</div><div class="cal-day-name">Ven</div><div class="cal-day-name">Sam</div><div class="cal-day-name">Dim</div>
            <div class="cal-grid-body" style="display:contents"></div>
          </div>
          <div style="display:flex;gap:14px;margin-top:8px;justify-content:flex-end">
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#2196F3"></div>FNC</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#EF4444"></div>FAC</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#7C3AED"></div>Plan</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="g2" style="align-items:stretch">
    <div class="nc-card" style="display:flex;flex-direction:column">
      <div class="nc-card-title">Évolution FNC &amp; FAC — Créées par RMQSE</div>
      <canvas id="evoChart" style="flex:1;min-height:130px"></canvas>
      <div style="display:flex;gap:12px;margin-top:6px;justify-content:flex-end">
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#5B8CDB"></div>FNC</div>
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#C9443A"></div>FAC</div>
      </div>
    </div>

    <div class="g4">

      <!-- 1. AUDIT INTERNE — compteurs FNC + FAC cliquables -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#7C3AED"></div>
        <div class="nc-kpi-label">Audit Interne</div>
        <div style="display:flex;gap:6px;margin-top:6px">
          <div class="aud-btn btn-list"
               data-model="nc_management.nonconformity"
               data-domain='[["type_audit_interne","=",true]]'
               data-context='{"search_default_mes_fnc":0,"default_type_audit_interne":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FNC</div>
            <div class="aud-btn-val" style="color:#1d4ed8"><t t-esc="widget.stats.fnc_audit_interne"/></div>
          </div>
          <div class="aud-btn btn-list"
               data-model="nc_management.corrective_action"
               data-domain='[["fnc_id.type_audit_interne","=",true]]'
               data-context='{"fnc_audit_domain":[["type_audit_interne","=",true]],"default_type_audit_interne":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FAC</div>
            <div class="aud-btn-val" style="color:#991b1b"><t t-esc="widget.stats.fac_audit_interne"/></div>
          </div>
        </div>
      </div>

      <!-- 2. AUDIT EXTERNE — compteurs FNC + FAC cliquables -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#FF9800"></div>
        <div class="nc-kpi-label">Audit Externe</div>
        <div style="display:flex;gap:6px;margin-top:6px">
          <div class="aud-btn btn-list"
               data-model="nc_management.nonconformity"
               data-domain='[["type_audit_externe","=",true]]'
               data-context='{"search_default_mes_fnc":0,"default_type_audit_externe":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FNC</div>
            <div class="aud-btn-val" style="color:#1d4ed8"><t t-esc="widget.stats.fnc_audit_externe"/></div>
          </div>
          <div class="aud-btn btn-list"
               data-model="nc_management.corrective_action"
               data-domain='[["fnc_id.type_audit_externe","=",true]]'
               data-context='{"fnc_audit_domain":[["type_audit_externe","=",true]],"default_type_audit_externe":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FAC</div>
            <div class="aud-btn-val" style="color:#991b1b"><t t-esc="widget.stats.fac_audit_externe"/></div>
          </div>
        </div>
      </div>

      <!-- 3. TOTAL FNC — Brouillon · Soumise · En cours · Validée -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#2196F3"></div>
        <div class="nc-kpi-label">Total FNC</div>
        <div class="nc-kpi-val" style="color:#1565C0"><t t-esc="widget.stats.fnc_total"/></div>
        <div class="nc-kpi-sub">↳ Taux validation : <t t-esc="widget.stats.taux_cloture"/>%</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
          <span class="badge" style="background:#f1f5f9;color:#475569">Brouillon <t t-esc="widget.stats.fnc_brouillon"/></span>
          <span class="badge orange">Soumise <t t-esc="widget.stats.fnc_envoyes"/></span>
          <span class="badge blue">En cours <t t-esc="widget.stats.fnc_cours"/></span>
          <span class="badge" style="background:#d1fae5;color:#065f46">Validée <t t-esc="widget.stats.fnc_validated"/></span>
        </div>
      </div>

      <!-- 4. TOTAL FAC — Brouillon · Soumise · En cours · Validée · Clôturée -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#10B981"></div>
        <div class="nc-kpi-label">Total FAC</div>
        <div class="nc-kpi-val" style="color:#065F46"><t t-esc="widget.stats.fac_total"/></div>
        <div class="nc-kpi-sub">↳ Taux efficacité : <t t-esc="widget.stats.taux_efficacite"/>%</div>
        <div class="nc-kpi-sub">↳ Taux clôture : <t t-esc="widget.stats.taux_cloture_fac"/>%</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
          <span class="badge" style="background:#f1f5f9;color:#475569">Brouillon <t t-esc="widget.stats.fac_brouillon"/></span>
          <span class="badge orange">Soumise <t t-esc="widget.stats.fac_open"/></span>
          <span class="badge" style="background:#dbeafe;color:#1e40af">En cours <t t-esc="widget.stats.fac_verif"/></span>
          <span class="badge" style="background:#d1fae5;color:#065f46">Validée <t t-esc="widget.stats.fac_validated"/></span>
          <span class="badge green">Clôturée <t t-esc="widget.stats.fac_closed"/></span>
        </div>
      </div>

      <!-- 5. PLANS SMI REÇUS — pleine largeur -->
      <div class="nc-kpi" style="grid-column:1/-1;background:linear-gradient(135deg,#faf5ff 0%,#f5f3ff 100%);border-color:#e9d5ff">
        <div class="nc-kpi-top" style="background:linear-gradient(90deg,#6d28d9,#7c3aed)"></div>
        <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
          <div>
            <div class="nc-kpi-label">Plans SMI reçus</div>
            <div class="nc-kpi-val" style="color:#5B21B6"><t t-esc="widget.stats.plan_total"/></div>
          </div>
          <div style="height:36px;width:1px;background:#e9d5ff;flex-shrink:0"></div>
          <div style="flex:1;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <span class="badge" style="background:#f5f3ff;color:#6d28d9;border:1px solid #ddd6fe">En attente <t t-esc="widget.stats.plan_en_attente"/></span>
            <span class="badge" style="background:#f0fdf4;color:#059669;border:1px solid #bbf7d0">Intégrés <t t-esc="widget.stats.plan_integres"/></span>
          </div>
          <div class="nc-kpi-sub btn-list" data-model="nc_management.plan_action_smi" data-domain='[["sent_to_rmqse","=",true],["is_global","=",false]]' style="flex-shrink:0;margin:0">↳ Voir tous →</div>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="nc-section-hdr autres">
  <span>Autres services / Départements / Directions</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="g2" style="align-items:stretch">
    <div class="nc-card">
      <div class="nc-card-title">FNC &amp; FAC par direction</div>
      <div class="nc-card-sub">Barres groupées · Cliquer sur une barre FNC pour afficher les types</div>

      <!-- Total global toutes directions + départements + services -->
      <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;padding:8px 12px;background:#f0f9ff;border-radius:8px;border:1px solid #bae6fd">
        <div style="font-size:11px;font-weight:700;color:#0369a1;flex:1">Total global (tous espaces)</div>
        <span class="badge blue">FNC <t t-esc="widget.stats.global_fnc_total"/></span>
        <span class="badge red">FAC <t t-esc="widget.stats.global_fac_total"/></span>
      </div>

      <t t-foreach="widget.stats.direction_stats" t-as="dept">
        <div class="gc-row">
          <div class="gc-lbl" style="cursor:pointer" t-att-data-direction="dept.name" t-att-data-direction-id="dept.id"><t t-esc="dept.name"/></div>
          <div class="gc-bars">
            <div class="gc-bar-fnc dir-bar" t-att-data-direction="dept.name" t-att-data-direction-id="dept.id" data-kind="fnc" t-att-style="'width:'+dept.pct_fnc+'%'"></div>
            <div class="gc-bar-fac" t-att-style="'width:'+dept.pct_fac+'%'"></div>
          </div>
          <div class="gc-vals">
            <div class="gc-v"><t t-esc="dept.fnc_count"/></div>
            <div class="gc-v"><t t-esc="dept.fac_count"/></div>
          </div>
        </div>
      </t>

      <div class="gc-legend">
        <div class="gc-leg-item"><div class="gc-leg-dot" style="background:#2196F3"></div>FNC</div>
        <div class="gc-leg-item"><div class="gc-leg-dot" style="background:#EF4444"></div>FAC</div>
      </div>

      <!-- Filtres département / service -->
      <div class="dir-filter-zone" style="display:none;margin-top:10px;border-top:1px solid #f1f5f9;padding-top:8px">
        <div class="dir-filter-dept-row" style="margin-bottom:6px">
          <div style="font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Départements</div>
          <div class="dir-dept-pills" style="display:flex;flex-wrap:wrap;gap:5px"></div>
        </div>
        <div class="dir-filter-svc-row" style="display:none;margin-bottom:6px">
          <div style="font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Services</div>
          <div class="dir-svc-pills" style="display:flex;flex-wrap:wrap;gap:5px"></div>
        </div>
      </div>

      <div style="margin-top:10px;border-top:1px solid #f1f5f9;padding-top:10px">
        <div class="nc-card-sub dir-pie-scope">Types FNC — Vue globale</div>
        <div class="dir-pie-title">Toutes directions</div>
        <div class="dir-pie"></div>
        <div class="dir-pie-legend" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;justify-content:center;font-size:10px;color:#64748b"></div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:8px">
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#FF9800"></div>
        <div class="nc-card-title scope-dir-title">Par direction</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-dir-fnc" style="color:#1565C0">—</div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-dir-fac" style="color:#991B1B">—</div></div>
        </div>
      </div>
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#10B981"></div>
        <div class="nc-card-title scope-dept-title">Par département</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-dept-fnc" style="color:#1565C0">—</div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-dept-fac" style="color:#991B1B">—</div></div>
        </div>
      </div>
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#7C3AED"></div>
        <div class="nc-card-title scope-svc-title">Par service</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-svc-fnc" style="color:#1565C0">—</div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-svc-fac" style="color:#991B1B">—</div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="nc-section-hdr globale">
  <span>Vue globale &amp; Alertes</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="g2">
    <div class="nc-card">
      <div class="nc-card-title">Diagramme global FNC &amp; FAC</div>
      <div class="nc-card-sub">RMQSE + Tous les services combinés — par mois</div>
      <canvas id="globalChart" style="height:170px"></canvas>
      <div style="display:flex;gap:12px;margin-top:8px;justify-content:center">
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#5B8CDB"></div>FNC</div>
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#C9443A"></div>FAC</div>
      </div>
    </div>

    <div class="nc-card">
      <div class="nc-card-title">Alertes &amp; Notifications</div>
      <div class="nc-card-sub">FAC à clôturer · FNC à valider · FAC non reçues &amp; à relancer</div>

      <t t-foreach="widget.stats.fac_a_cloturer" t-as="fac">
        <t t-if="fac.days > 7">
          <div class="nc-alert">
            <div style="flex:1">
              <div style="font-size:12px;font-weight:600;color:#991b1b"><t t-esc="fac.name"/> — À clôturer</div>
              <div style="font-size:11px;color:#b91c1c;margin-top:2px"><t t-esc="fac.department"/> · Retard <t t-esc="fac.days"/> jours</div>
            </div>
            <span class="badge red">Urgent</span>
            <div class="btn-sm primary btn-open" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac.id">Ouvrir</div>
          </div>
        </t>
        <t t-if="fac.days > 3 and fac.days &lt;= 7">
          <div class="nc-alert orange">
            <div style="flex:1">
              <div style="font-size:12px;font-weight:600;color:#9a3412"><t t-esc="fac.name"/> — À clôturer</div>
              <div style="font-size:11px;color:#c2410c;margin-top:2px"><t t-esc="fac.department"/> · Dans <t t-esc="fac.days"/> jours</div>
            </div>
            <span class="badge orange">Bientôt</span>
            <div class="btn-sm btn-open" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac.id">Ouvrir</div>
          </div>
        </t>
      </t>

      <t t-foreach="widget.stats.fnc_retard_list" t-as="fnc">
        <div class="nc-alert orange">
          <div style="flex:1">
            <div style="font-size:12px;font-weight:600;color:#9a3412"><t t-esc="fnc.name"/> — À valider</div>
            <div style="font-size:11px;color:#c2410c;margin-top:2px"><t t-esc="fnc.department"/> · <t t-esc="fnc.days"/> jours en cours</div>
          </div>
          <div class="btn-sm btn-open" t-att-data-model="'nc_management.nonconformity'" t-att-data-id="fnc.id">Ouvrir</div>
        </div>
      </t>

      <t t-if="widget.stats.fac_non_recues.length">
        <div style="margin-top:10px;padding-top:8px;border-top:1px solid #ede9fe">
          <div style="font-size:10px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px">FAC non reçues — validées par d'autres, à clôturer</div>
          <t t-foreach="widget.stats.fac_non_recues" t-as="fac_nr">
            <div class="nc-alert" style="border-left:3px solid #7c3aed;border-color:#ede9fe;background:#faf5ff;margin-bottom:7px">
              <div style="flex:1">
                <div style="font-size:12px;font-weight:600;color:#5b21b6"><t t-esc="fac_nr.name"/> — À clôturer</div>
                <div style="font-size:11px;color:#6d28d9;margin-top:2px">
                  <t t-if="fac_nr.fnc_name">FNC : <t t-esc="fac_nr.fnc_name"/> · </t><t t-esc="fac_nr.department"/> · Retard <t t-esc="fac_nr.days"/>j
                </div>
                <t t-if="fac_nr.owner">
                  <div style="font-size:10px;color:#94a3b8;margin-top:1px">Utilisateur : <t t-esc="fac_nr.owner"/></div>
                </t>
              </div>
              <span class="badge purple">Urgent</span>
              <div class="btn-sm primary" style="background:#7c3aed;border-color:#7c3aed" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac_nr.id" data-action="open-fac-nr">Ouvrir FAC</div>
              <div class="btn-sm btn-reply" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac_nr.id">Relancer</div>
            </div>
          </t>
        </div>
      </t>
    </div>
  </div>
</div>

</div>
</div>
</t>

<t t-name="NcPlanSmi">
<div style="padding:24px;background:#f4f6f9;
            min-height:100vh;font-family:Arial,sans-serif;">

  <!-- Title -->
  <div style="background:white;border-radius:8px;padding:16px 20px;
              margin-bottom:20px;border-left:5px solid #2c3e50;
              display:flex; justify-content:space-between; align-items:center;">
    <div>
      <h3 style="margin:0;color:#2c3e50;font-size:16px;">
          Analyse de l'Efficacité — Plan SMI
      </h3>
      <p style="margin:4px 0 0;font-size:12px;color:#888;">
          Cimenterie de Sétif · Catégories liées aux FNC
      </p>
    </div>
    <button name="export_smi" class="o_export_smi"
            style="background:#1e40af;color:white;border:1px solid #1e40af;
                   border-radius:6px;padding:5px 14px;font-size:12px;
                   font-weight:700;cursor:pointer;transition:background .15s;"
            onmouseover="this.style.background='#1d4ed8'"
            onmouseout="this.style.background='#1e40af'">
        <i class="fa fa-file-excel-o"></i> Export
    </button>
  </div>

  <!-- Table Analyse Efficacité Globale -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Analyse Efficacité Globale
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#2c3e50;color:white;">
          <th style="padding:10px 12px;border:1px solid #1a252f;
                     text-align:left;min-width:130px;"></th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Non efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé 100%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé plus 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisée moins 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Taux Efficacité%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Total</th>
        </tr>
      </thead>
      <tbody id="smi_body">
        <tr>
          <td colspan="8" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Graphe Taux d'efficacité par catégorie (%) -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux d'efficacité par catégorie (%)
    </h4>
    <div style="position:relative;overflow-x:auto;">
      <canvas id="smi_chart"></canvas>
    </div>
  </div>

  <!-- Table Taux réalisation processus -->
  <div style="background:white;border-radius:8px;padding:20px;
              box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux de réalisation (revue processus)
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#f8f9fa;">
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;">
              Processus
          </th>
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:260px;">
              Taux de réalisation
          </th>
          <th style="text-align:center;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:80px;">
              %
          </th>
        </tr>
      </thead>
      <tbody id="proc_body">
        <tr>
          <td colspan="3" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

</div>
</t>

<!-- ═══════════════════════════════════════════════════════════════════════
     DASHBOARD NC UTILISATEUR
════════════════════════════════════════════════════════════════════════ -->
<t t-name="NcUserDashboard">
<div class="nc-db">
<div class="nc-inner">

  <div class="nc-header">
    <div>
      <div class="nc-brand-sub">NC MANAGEMENT</div>
      <div class="nc-brand-title">Dashboard</div>
    </div>
    <div class="nc-header-right">
      <span class="nc-update">Today: <t t-esc="widget.stats.today"></t></span>
    </div>
  </div>

  <!-- FNC -->
  <div class="nc-section-hdr rmqse">
    <span>FNC — Non-Conformity Reports</span>
    <div class="nc-section-hdr-sep"></div>
    <span>Total: <t t-esc="widget.stats.fnc_total"></t></span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:12px">
    <div class="nc-kpi" data-filter="fnc_total" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#2196F3"></div>
      <div class="nc-kpi-label">Total FNC</div>
      <div class="nc-kpi-val" style="color:#1565C0"><t t-esc="widget.stats.fnc_total"></t></div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
        <span class="badge" style="background:#f1f5f9;color:#475569">Draft <t t-esc="widget.stats.fnc_brouillon"></t></span>
        <span class="badge orange">Submitted <t t-esc="widget.stats.fnc_submitted"></t></span>
        <span class="badge blue">In progress <t t-esc="widget.stats.fnc_cours"></t></span>
      </div>
    </div>
    <div class="nc-kpi" data-filter="fnc_cours" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#FF9800"></div>
      <div class="nc-kpi-label">In Progress</div>
      <div class="nc-kpi-val" style="color:#9a3412"><t t-esc="widget.stats.fnc_submitted + widget.stats.fnc_cours"></t></div>
      <div class="nc-kpi-sub"><t t-esc="widget.stats.fnc_submitted"></t> submitted · <t t-esc="widget.stats.fnc_cours"></t> in processing</div>
    </div>
    <div class="nc-kpi" data-filter="fnc_closed" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#10B981"></div>
      <div class="nc-kpi-label">Closed</div>
      <div class="nc-kpi-val" style="color:#166534"><t t-esc="widget.stats.fnc_validated + widget.stats.fnc_closed"></t></div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
        <span class="badge" style="background:#d1fae5;color:#065f46">Validated <t t-esc="widget.stats.fnc_validated"></t></span>
        <span class="badge green">Closed <t t-esc="widget.stats.fnc_closed"></t></span>
      </div>
    </div>
  </div>

  <!-- FAC -->
  <div class="nc-section-hdr autres">
    <span>FAC — Corrective Actions</span>
    <div class="nc-section-hdr-sep"></div>
    <span>Total: <t t-esc="widget.stats.fac_total"></t></span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:12px">
    <div class="nc-kpi" data-filter="fac_total" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#EF4444"></div>
      <div class="nc-kpi-label">Total FAC</div>
      <div class="nc-kpi-val" style="color:#991b1b"><t t-esc="widget.stats.fac_total"></t></div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
        <span class="badge orange">Submitted <t t-esc="widget.stats.fac_submitted"></t></span>
        <span class="badge blue">In progress <t t-esc="widget.stats.fac_cours"></t></span>
      </div>
    </div>
    <div class="nc-kpi" data-filter="fac_cours" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#FF9800"></div>
      <div class="nc-kpi-label">In Progress</div>
      <div class="nc-kpi-val" style="color:#9a3412"><t t-esc="widget.stats.fac_submitted + widget.stats.fac_cours"></t></div>
      <div class="nc-kpi-sub">Pending actions</div>
    </div>
    <div class="nc-kpi" data-filter="fac_closed" style="cursor:pointer">
      <div class="nc-kpi-top" style="background:#10B981"></div>
      <div class="nc-kpi-label">Closed</div>
      <div class="nc-kpi-val" style="color:#166534"><t t-esc="widget.stats.fac_validated + widget.stats.fac_closed"></t></div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
        <span class="badge" style="background:#d1fae5;color:#065f46">Validated <t t-esc="widget.stats.fac_validated"></t></span>
        <span class="badge green">Closed <t t-esc="widget.stats.fac_closed"></t></span>
      </div>
    </div>
  </div>

  <!-- Received docs + Calendar (same layout as RMQSE) -->
  <div class="section-title">Calendar — FNC &amp; FAC</div>
  <div class="g2">

    <!-- Fiches reçues -->
    <div class="nc-card" style="max-height:420px;overflow-y:auto">
      <div class="nc-card-title">My Reports</div>
      <div class="nc-card-sub received-sub">Today's documents</div>
      <div class="received-list"></div>
    </div>

    <!-- Calendrier avec sélecteur identique au RMQSE -->
    <div style="display:flex;flex-direction:column;gap:8px">
      <div class="nc-card">
        <div class="nc-card-title" style="margin-bottom:8px">Calendar</div>
        <div class="cal-wrap">
          <div class="cal-header-pick">
            <div class="cal-month-label" style="font-size:13px;font-weight:700;color:#1e293b">Loading...</div>
            <span style="font-size:11px;color:#94a3b8">&#9660;</span>
          </div>
          <div class="cal-picker" style="display:none;background:#f0f4ff;border:1px solid #c7d7f8;border-radius:8px;padding:8px;margin-bottom:8px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
              <button class="cal-btn cal-yr-prev">&#8249;</button>
              <span class="cal-picker-yr" style="font-size:13px;font-weight:700;color:#1e293b">2026</span>
              <button class="cal-btn cal-yr-next">&#8250;</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px">
              <div class="cal-pm" data-m="0">Jan</div><div class="cal-pm" data-m="1">Feb</div>
              <div class="cal-pm" data-m="2">Mar</div><div class="cal-pm" data-m="3">Apr</div>
              <div class="cal-pm" data-m="4">May</div><div class="cal-pm" data-m="5">Jun</div>
              <div class="cal-pm" data-m="6">Jul</div><div class="cal-pm" data-m="7">Aug</div>
              <div class="cal-pm" data-m="8">Sep</div><div class="cal-pm" data-m="9">Oct</div>
              <div class="cal-pm" data-m="10">Nov</div><div class="cal-pm" data-m="11">Dec</div>
            </div>
          </div>
          <div class="cal-grid">
            <div class="cal-day-name">Mon</div><div class="cal-day-name">Tue</div><div class="cal-day-name">Wed</div><div class="cal-day-name">Thu</div><div class="cal-day-name">Fri</div><div class="cal-day-name">Sat</div><div class="cal-day-name">Sun</div>
            <div class="cal-grid-body" style="display:contents"></div>
          </div>
          <div style="display:flex;gap:14px;margin-top:8px;justify-content:flex-end">
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#2196F3"></div>FNC</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#EF4444"></div>FAC</div>
          </div>
        </div>
      </div>

      <!-- Diagramme mensuel -->
      <div class="nc-card" style="display:flex;flex-direction:column">
        <div class="nc-card-title">Monthly Evolution (6 months)</div>
        <div style="display:flex;gap:12px;margin-bottom:6px">
          <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#5B8CDB"></div>FNC</div>
          <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#C9443A"></div>FAC</div>
        </div>
        <canvas id="udChart" style="height:160px;max-height:160px"></canvas>
      </div>
    </div>
  </div>

  <!-- Alerts -->
  <div class="nc-section-hdr globale">
    <span>Alerts</span>
    <div class="nc-section-hdr-sep"></div>
    <span><t t-esc="widget.stats.alerts.length"></t> alert(s)</span>
  </div>

  <t t-if="!widget.stats.alerts.length">
    <div class="nc-empty">No active alerts — everything is up to date.</div>
  </t>
  <t t-foreach="widget.stats.alerts" t-as="alert">
    <t t-if="alert.badge === 'red'">
      <div class="nc-alert">
        <div style="flex:1">
          <div style="font-size:12px;font-weight:600;color:#991b1b">
            <span class="badge red" style="margin-right:6px"><t t-esc="alert.kind"></t></span><t t-esc="alert.name"></t>
          </div>
          <div style="font-size:11px;color:#b91c1c;margin-top:2px"><t t-esc="alert.label"></t></div>
        </div>
        <div class="btn-sm primary btn-open" t-att-data-model="alert.model" t-att-data-id="alert.id">Open</div>
      </div>
    </t>
    <t t-if="alert.badge === 'orange'">
      <div class="nc-alert orange">
        <div style="flex:1">
          <div style="font-size:12px;font-weight:600;color:#9a3412">
            <span class="badge orange" style="margin-right:6px"><t t-esc="alert.kind"></t></span><t t-esc="alert.name"></t>
          </div>
          <div style="font-size:11px;color:#c2410c;margin-top:2px"><t t-esc="alert.label"></t></div>
        </div>
        <div class="btn-sm btn-open" t-att-data-model="alert.model" t-att-data-id="alert.id">Open</div>
      </div>
    </t>
  </t>

</div>
</div>
</t>

</templates>
