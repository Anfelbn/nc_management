<?xml version="1.0" encoding="utf-8"?>
<templates>
<t t-name="NcDashboard">
<div style="padding:20px;background:#F3F4F6;
            min-height:100vh;font-family:Arial,sans-serif;">

  <!-- Top bar -->
  <div style="display:flex;justify-content:space-between;
              align-items:center;margin-bottom:18px;">
    <div>
      <div style="font-size:11px;color:#6B7280;margin-bottom:2px;">
          CIMENTERIE DE SÉTIF — GICA</div>
      <div style="font-size:16px;font-weight:600;color:#111827;">Dashboard RMQE</div>
      <div style="font-size:11px;color:#6B7280;">
          Fiches Non-Conformité &amp; Actions Correctives</div>
    </div>
  </div>

  <!-- Section FNC -->
  <div style="font-size:11px;font-weight:600;letter-spacing:.5px;
              color:#374151;text-transform:uppercase;
              margin-bottom:10px;">Fiches Non-Conformité (FNC)</div>

  <div style="display:grid;grid-template-columns:repeat(5,1fr);
              gap:10px;margin-bottom:10px;">
    <div style="background:#EBF5FF;border:1px solid #BFDBFE;
                border-top:4px solid #2196F3;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Total FNC</div>
      <div id="fnc_total" style="font-size:26px;font-weight:500;color:#1565C0;">0</div>
    </div>
    <div style="background:#FFF8E8;border:1px solid #FDE68A;
                border-top:4px solid #FF9800;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">En cours</div>
      <div id="fnc_cours" style="font-size:26px;font-weight:500;color:#E65100;">0</div>
    </div>
    <div style="background:#F3EEFF;border:1px solid #DDD6FE;
                border-top:4px solid #7C3AED;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Envoyées dép.</div>
      <div id="fnc_envoyes" style="font-size:26px;font-weight:500;color:#5B21B6;">0</div>
    </div>
    <div style="background:#E8F8F1;border:1px solid #A7F3D0;
                border-top:4px solid #10B981;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Clôturées</div>
      <div id="fnc_closed" style="font-size:26px;font-weight:500;color:#065F46;">0</div>
    </div>
    <div style="background:#FEF2F2;border:1px solid #FECACA;
                border-top:4px solid #EF4444;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">En retard</div>
      <div id="fnc_retard" style="font-size:26px;font-weight:500;color:#991B1B;">0</div>
      <div style="font-size:10px;color:#9CA3AF;margin-top:3px;">&gt; 7 jours</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:2fr 3fr;
              gap:10px;margin-bottom:14px;">
    <div style="background:#E8F8F1;border:1px solid #A7F3D0;
                border-top:4px solid #10B981;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Taux clôture</div>
      <div id="taux_cloture" style="font-size:28px;font-weight:500;color:#065F46;">0%</div>
    </div>
    <div style="background:#EBF5FF;border:1px solid #BFDBFE;
                border-top:4px solid #2196F3;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">
          FNC reçues des autres services / départements</div>
      <div id="fnc_recues" style="font-size:28px;font-weight:500;color:#1565C0;">0</div>
    </div>
  </div>

  <!-- Section FAC -->
  <div style="font-size:11px;font-weight:600;letter-spacing:.5px;
              color:#374151;text-transform:uppercase;
              margin-bottom:10px;">Fiches Action Corrective (FAC)</div>

  <div style="display:grid;grid-template-columns:repeat(5,1fr);
              gap:10px;margin-bottom:10px;">
    <div style="background:#EBF5FF;border:1px solid #BFDBFE;
                border-top:4px solid #2196F3;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Total FAC</div>
      <div id="fac_total" style="font-size:26px;font-weight:500;color:#1565C0;">0</div>
    </div>
    <div style="background:#FFF8E8;border:1px solid #FDE68A;
                border-top:4px solid #FF9800;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Ouvertes</div>
      <div id="fac_open" style="font-size:26px;font-weight:500;color:#E65100;">0</div>
    </div>
    <div style="background:#F3EEFF;border:1px solid #DDD6FE;
                border-top:4px solid #7C3AED;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Vérifiées</div>
      <div id="fac_verif" style="font-size:26px;font-weight:500;color:#5B21B6;">0</div>
    </div>
    <div style="background:#E8F8F1;border:1px solid #A7F3D0;
                border-top:4px solid #10B981;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Clôturées</div>
      <div id="fac_closed" style="font-size:26px;font-weight:500;color:#065F46;">0</div>
    </div>
    <div style="background:#FEF2F2;border:1px solid #FECACA;
                border-top:4px solid #EF4444;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">En retard</div>
      <div id="fac_retard" style="font-size:26px;font-weight:500;color:#991B1B;">0</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:2fr 3fr;
              gap:10px;margin-bottom:20px;">
    <div style="background:#E8F8F1;border:1px solid #A7F3D0;
                border-top:4px solid #10B981;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">Taux efficacité</div>
      <div id="taux_eff" style="font-size:28px;font-weight:500;color:#065F46;">0%</div>
    </div>
    <div style="background:#FFF8E8;border:1px solid #FDE68A;
                border-top:4px solid #FF9800;border-radius:10px;
                padding:14px;text-align:center;">
      <div style="font-size:11px;color:#4B5563;margin-bottom:6px;">
          FAC à clôturer reçues (en attente approbation RMQE)</div>
      <div id="fac_recues" style="font-size:28px;font-weight:500;color:#E65100;">0</div>
    </div>
  </div>

  <!-- Graphes ligne 1 -->
  <div style="display:grid;grid-template-columns:1.3fr 1fr;
              gap:14px;margin-bottom:14px;">

    <div style="background:white;border:1px solid #E5E7EB;
                border-left:4px solid #2196F3;border-radius:12px;padding:16px;">
      <div style="font-size:13px;font-weight:500;color:#1F2937;margin-bottom:2px;">
          Évolution FNC &amp; FAC</div>
      <div style="font-size:11px;color:#6B7280;margin-bottom:12px;">6 derniers mois</div>
      <canvas id="evo_chart" height="110"></canvas>
    </div>

    <div style="background:white;border:1px solid #E5E7EB;
                border-left:4px solid #7C3AED;border-radius:12px;padding:16px;">
      <div style="font-size:13px;font-weight:500;color:#1F2937;margin-bottom:2px;">
          FNC par type</div>
      <div style="font-size:11px;color:#6B7280;margin-bottom:12px;">
          Répartition par catégorie</div>
      <canvas id="type_chart" height="110"></canvas>
    </div>

  </div>

  <!-- Graphes ligne 2 -->
  <div style="display:grid;grid-template-columns:1fr 1fr;
              gap:14px;margin-bottom:14px;">

    <div style="background:white;border:1px solid #E5E7EB;
                border-left:4px solid #2196F3;border-radius:12px;padding:16px;">
      <div style="font-size:13px;font-weight:500;color:#1F2937;margin-bottom:2px;">
          FNC par département</div>
      <div style="font-size:11px;color:#6B7280;margin-bottom:12px;">
          Reçues des autres services</div>
      <canvas id="dept_chart" height="110"></canvas>
    </div>

    <div style="background:white;border:1px solid #E5E7EB;
                border-left:4px solid #10B981;border-radius:12px;padding:16px;">
      <div style="font-size:13px;font-weight:500;color:#1F2937;margin-bottom:8px;">
          États FNC &amp; FAC</div>
      <div style="display:flex;justify-content:space-between;align-items:center;
                  padding:7px 0;border-bottom:1px solid #F3F4F6;">
        <div style="font-size:12px;color:#4B5563;">FNC clôturées</div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:120px;height:6px;background:#E5E7EB;
                      border-radius:3px;overflow:hidden;">
            <div id="s_fnc_closed_bar" style="height:100%;border-radius:3px;
                 width:0%;"></div></div>
          <div id="s_fnc_closed_pct" style="font-size:12px;font-weight:500;
               min-width:34px;text-align:right;color:#065F46;">0%</div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;
                  padding:7px 0;border-bottom:1px solid #F3F4F6;">
        <div style="font-size:12px;color:#4B5563;">FNC en cours</div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:120px;height:6px;background:#E5E7EB;
                      border-radius:3px;overflow:hidden;">
            <div id="s_fnc_cours_bar" style="height:100%;border-radius:3px;
                 width:0%;"></div></div>
          <div id="s_fnc_cours_pct" style="font-size:12px;font-weight:500;
               min-width:34px;text-align:right;color:#1565C0;">0%</div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;
                  padding:7px 0;border-bottom:1px solid #F3F4F6;">
        <div style="font-size:12px;color:#4B5563;">FAC efficaces</div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:120px;height:6px;background:#E5E7EB;
                      border-radius:3px;overflow:hidden;">
            <div id="s_fac_eff_bar" style="height:100%;border-radius:3px;
                 width:0%;"></div></div>
          <div id="s_fac_eff_pct" style="font-size:12px;font-weight:500;
               min-width:34px;text-align:right;color:#065F46;">0%</div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;
                  padding:7px 0;border-bottom:1px solid #F3F4F6;">
        <div style="font-size:12px;color:#4B5563;">FAC en retard</div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:120px;height:6px;background:#E5E7EB;
                      border-radius:3px;overflow:hidden;">
            <div id="s_fac_retard_bar" style="height:100%;border-radius:3px;
                 width:0%;"></div></div>
          <div id="s_fac_retard_pct" style="font-size:12px;font-weight:500;
               min-width:34px;text-align:right;color:#991B1B;">0%</div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;
                  padding:7px 0;">
        <div style="font-size:12px;color:#4B5563;">FNC en retard</div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:120px;height:6px;background:#E5E7EB;
                      border-radius:3px;overflow:hidden;">
            <div id="s_fnc_retard_bar" style="height:100%;border-radius:3px;
                 width:0%;"></div></div>
          <div id="s_fnc_retard_pct" style="font-size:12px;font-weight:500;
               min-width:34px;text-align:right;color:#991B1B;">0%</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Alertes ligne 3 -->
  <div style="display:grid;grid-template-columns:1fr 1fr;
              gap:14px;margin-bottom:14px;">

    <div style="background:white;border:1px solid #E5E7EB;
                border-radius:12px;padding:16px;">
      <div style="display:flex;justify-content:space-between;
                  align-items:center;margin-bottom:12px;">
        <div style="font-size:13px;font-weight:500;color:#1F2937;">FAC à clôturer</div>
        <span id="fac_retard_badge" style="font-size:10px;padding:2px 8px;
              border-radius:99px;background:#FEF2F2;color:#991B1B;">urgentes</span>
      </div>
      <div id="fac_cloturer_list"></div>
    </div>

    <div style="background:white;border:1px solid #E5E7EB;
                border-radius:12px;padding:16px;">
      <div style="display:flex;justify-content:space-between;
                  align-items:center;margin-bottom:12px;">
        <div style="font-size:13px;font-weight:500;color:#1F2937;">FNC en retard</div>
        <span style="font-size:10px;padding:2px 8px;border-radius:99px;
              background:#FEF2F2;color:#991B1B;">fiches</span>
      </div>
      <div id="fnc_retard_list"></div>
      <div style="height:1px;background:#F3F4F6;margin:12px 0;"></div>
      <div style="font-size:13px;font-weight:500;color:#1F2937;margin-bottom:10px;">
          FNC reçues des départements</div>
      <div id="dept_mini_list"></div>
    </div>

  </div>

</div>
</t>

<t t-name="NcPlanSmi">
<div style="padding:24px;background:#f4f6f9;
            min-height:100vh;font-family:Arial,sans-serif;">

  <!-- Title -->
  <div style="background:white;border-radius:8px;padding:16px 20px;
              margin-bottom:20px;border-left:5px solid #2c3e50;
              display:flex; justify-content:space-between; align-items:center;">
    <div>
      <h3 style="margin:0;color:#2c3e50;font-size:16px;">
          Analyse de l'Efficacité — Plan SMI
      </h3>
      <p style="margin:4px 0 0;font-size:12px;color:#888;">
          Cimenterie de Sétif · Catégories liées aux FNC
      </p>
    </div>
    <button class="btn btn-primary o_export_smi" style="font-size:13px; font-weight:bold;">
        <i class="fa fa-file-excel-o"></i> Export
    </button>
  </div>

  <!-- Table Analyse Efficacité Globale -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Analyse Efficacité Globale
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#2c3e50;color:white;">
          <th style="padding:10px 12px;border:1px solid #1a252f;
                     text-align:left;min-width:130px;"></th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Non efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé 100%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé plus 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisée moins 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Taux Efficacité%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Total</th>
        </tr>
      </thead>
      <tbody id="smi_body">
        <tr>
          <td colspan="8" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Graphe Taux efficacité en % -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux efficacité en %
    </h4>
    <canvas id="smi_chart" height="90"></canvas>
  </div>

  <!-- Table Taux réalisation processus -->
  <div style="background:white;border-radius:8px;padding:20px;
              box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux de réalisation (revue processus)
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#f8f9fa;">
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;">
              Processus
          </th>
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:260px;">
              Taux de réalisation
          </th>
          <th style="text-align:center;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:80px;">
              %
          </th>
        </tr>
      </thead>
      <tbody id="proc_body">
        <tr>
          <td colspan="3" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

</div>
</t>
</templates>
