<?xml version="1.0" encoding="utf-8"?>
<templates>
<t t-name="NcDashboard">
<div class="nc-db">
<style>
.nc-db *{box-sizing:border-box;margin:0;padding:0}
.nc-db{background:#f1f5f9;font-family:'Segoe UI',Arial,sans-serif;padding:16px;min-width:900px}
.nc-inner{max-width:1240px;margin:0 auto}
.nc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
.nc-brand-sub{font-size:10px;color:#94a3b8;letter-spacing:.5px}
.nc-brand-title{font-size:16px;font-weight:700;color:#0f172a}
.nc-header-right{display:flex;align-items:center;gap:12px}
.nc-period-label,.nc-update{font-size:11px;color:#94a3b8}
.pb{font-size:11px;padding:4px 12px;border-radius:20px;border:1px solid #e2e8f0;background:white;color:#64748b;cursor:pointer;transition:all .15s}
.pb:hover{border-color:#1e40af;color:#1e40af}
.pb.active{background:#1e40af;color:white;border-color:#1e40af}
.period-btn{display:flex;gap:5px}
.nc-section-hdr{display:flex;align-items:center;gap:14px;margin:22px 0 16px;padding:12px 18px;border-radius:10px;color:white;font-size:13px;font-weight:700;letter-spacing:.4px}
.nc-section-hdr.rmqse{background:linear-gradient(90deg,#1e3a8a,#2563eb)}
.nc-section-hdr.autres{background:linear-gradient(90deg,#065f46,#059669)}
.nc-section-hdr.globale{background:linear-gradient(90deg,#581c87,#7c3aed)}
.nc-section-hdr-sep{flex:1;height:1px;background:rgba(255,255,255,.25)}
.section-title{font-size:10px;font-weight:700;letter-spacing:1px;color:#94a3b8;text-transform:uppercase;margin-bottom:10px;padding-left:2px}
.nc-card{background:white;border:1px solid #e2e8f0;border-radius:12px;padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.nc-card-title{font-size:13px;font-weight:700;color:#1e293b;margin-bottom:3px}
.nc-card-sub{font-size:11px;color:#94a3b8;margin-bottom:10px}
.nc-kpi{background:white;border-radius:12px;padding:12px 14px;border:1px solid #e2e8f0;position:relative;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.nc-kpi-top{width:100%;height:3px;border-radius:3px 3px 0 0;position:absolute;top:0;left:0}
.nc-kpi-label{font-size:11px;color:#64748b;margin-bottom:5px;margin-top:4px}
.nc-kpi-val{font-size:24px;font-weight:700;line-height:1}
.nc-kpi-sub{font-size:10px;color:#94a3b8;margin-top:4px;cursor:pointer;text-decoration:underline}
.nc-kpi-sub:hover{color:#1e40af}
.badge{font-size:10px;padding:2px 7px;border-radius:99px;font-weight:500}
.badge.red{background:#fef2f2;color:#991b1b}
.badge.blue{background:#eff6ff;color:#1d4ed8}
.badge.green{background:#f0fdf4;color:#166534}
.badge.orange{background:#fff7ed;color:#9a3412}
.badge.purple{background:#f5f3ff;color:#6d28d9}
.nc-notif{display:flex;gap:10px;align-items:flex-start;padding:10px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:7px;background:#fafafa;transition:background .2s}
.nc-notif:hover{background:#f0f9ff}
.nc-avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.avatar-blue{background:#EBF5FF;color:#1565C0}
.avatar-red{background:#FEF2F2;color:#991B1B}
.avatar-purple{background:#F5F3FF;color:#6D28D9}
.nc-notif-body{flex:1;min-width:0}
.nc-notif-ref{font-size:12px;font-weight:600;color:#1e293b}
.nc-notif-info{font-size:11px;color:#64748b;margin-top:2px}
.nc-notif-actions{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
.btn-sm{font-size:10px;padding:3px 10px;border-radius:6px;border:1px solid #e2e8f0;background:white;color:#1e40af;cursor:pointer;transition:all .15s}
.btn-sm:hover{background:#eff6ff}
.btn-sm.primary{background:#1e40af;color:white;border-color:#1e40af}
.btn-sm.primary:hover{background:#1d4ed8}
.nc-alert{display:flex;gap:10px;align-items:center;padding:10px;border-radius:0 8px 8px 0;border:1px solid #fee2e2;border-left:3px solid #EF4444;background:#fef2f2;margin-bottom:7px}
.nc-alert.orange{border-left-color:#FF9800;border-color:#ffedd5;background:#fff7ed}
.nc-alert.green{border-left-color:#10B981;border-color:#d1fae5;background:#f0fdf4}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.g4{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.cal-wrap{font-size:12px;user-select:none}
.cal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.cal-month-label{font-size:14px;font-weight:700;color:#1e293b}
.cal-nav{display:flex;gap:6px}
.cal-btn{width:26px;height:26px;border-radius:6px;border:1px solid #e2e8f0;background:white;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;color:#64748b;transition:all .15s}
.cal-btn:hover{background:#f1f5f9}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-day-name{font-size:10px;font-weight:600;color:#94a3b8;text-align:center;padding:4px 0}
.cal-day{text-align:center;padding:5px 2px;border-radius:6px;cursor:pointer;font-size:12px;color:#374151;transition:background .15s;min-height:30px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.cal-day:hover{background:#f1f5f9}
.cal-day.other-month{color:#d1d5db}
.cal-day.today{background:#1e40af;color:white;font-weight:700}
.cal-day.selected{outline:2px solid #1e40af;background:#dbeafe;color:#1e3a8a;font-weight:700}
.cal-day.today.selected{outline:2px solid #0f172a;background:#1e40af;color:white}
.cal-dot-row{display:flex;gap:2px;justify-content:center;margin-top:1px}
.cdot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.nc-empty{font-size:12px;color:#94a3b8;text-align:center;padding:22px 8px;border:1px dashed #e2e8f0;border-radius:8px;background:#f8fafc}
.gc-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.gc-lbl{font-size:11px;color:#64748b;width:80px;text-align:right;flex-shrink:0}
.gc-bars{flex:1;display:flex;flex-direction:column;gap:3px}
.gc-bar-fnc{height:9px;border-radius:3px;background:#2196F3;transition:width .3s}
.gc-bar-fac{height:9px;border-radius:3px;background:#EF4444;transition:width .3s}
.gc-bar-fnc{cursor:pointer}
.gc-bar-fnc:hover{filter:brightness(.9)}
.gc-bar-fac{cursor:default}
.dir-bar.selected{outline:2px solid #0f172a}
.gc-vals{display:flex;flex-direction:column;gap:3px;width:28px}
.gc-v{font-size:10px;color:#64748b;line-height:9px;text-align:right}
.gc-legend{display:flex;gap:12px;margin-top:6px;justify-content:flex-end}
.gc-leg-item{display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b}
.gc-leg-dot{width:10px;height:10px;border-radius:2px}
.dir-pie{width:116px;height:116px;border-radius:50%;margin:8px auto;background:#e2e8f0}
.dir-pie-title{text-align:center;font-size:12px;font-weight:700;color:#1e293b;margin-top:8px}
.split-card{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}
.split-box{border:1px solid #e2e8f0;border-radius:8px;padding:10px;background:#f8fafc;text-align:center}
.split-label{font-size:10px;color:#64748b;margin-bottom:4px}
.split-val{font-size:24px;font-weight:700;line-height:1}
canvas{display:block;width:100%}
.cal-header-pick{display:flex;justify-content:space-between;align-items:center;cursor:pointer;border:1px solid #e2e8f0;border-radius:8px;padding:5px 10px;background:#f8fafc;margin-bottom:8px;transition:background .15s}
.cal-header-pick:hover{background:#dbeafe}
.cal-pm{font-size:11px;padding:6px 2px;border-radius:6px;border:1px solid #c7d7f8;background:white;color:#3b5cc4;cursor:pointer;text-align:center;transition:all .15s}
.cal-pm:hover{background:#dbeafe;border-color:#93c5fd}
.cal-pm.cal-pm-active{background:#1e40af;color:white;border-color:#1e40af}
.nc-kpi-txt{font-size:10px;color:#94a3b8;margin-top:4px}
.dir-pill{font-size:10px;padding:3px 10px;border-radius:99px;border:1px solid #e2e8f0;background:white;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap}
.dir-pill:hover{border-color:#1e40af;color:#1e40af;background:#eff6ff}
.dir-pill.active{background:#1e40af;color:white;border-color:#1e40af}
.dir-pill.dept-pill.active{background:#059669;border-color:#059669}
.dir-pill.svc-pill.active{background:#7c3aed;border-color:#7c3aed}
/* ── Boutons compteurs audit ──────────────────────────────── */
.aud-btn{flex:1;background:white;border:1px solid #e2e8f0;border-radius:8px;padding:7px 6px 6px;cursor:pointer;text-align:center;transition:all .15s;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.aud-btn:hover{border-color:#1e40af;background:#eff6ff;transform:translateY(-1px);box-shadow:0 3px 8px rgba(0,0,0,.12)}
.aud-btn-label{font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.6px;margin-bottom:4px}
.aud-btn-val{font-size:20px;font-weight:700;line-height:1}
/* ── Avatar cliquable ─────────────────────────────────────── */
.avatar-clickable{cursor:pointer;transition:transform .15s,box-shadow .15s}
.avatar-clickable:hover{transform:scale(1.12);box-shadow:0 3px 12px rgba(0,0,0,.28)}
/* ── Modal émetteur ───────────────────────────────────────── */
.nsm-overlay{position:fixed;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,.52);display:flex;align-items:center;justify-content:center;z-index:99999;opacity:0;transition:opacity .22s}
.nsm-overlay.nsm-visible{opacity:1}
.nsm-card{background:white;border-radius:18px;padding:28px 24px 22px;width:360px;max-width:92vw;position:relative;transform:translateY(20px) scale(.97);transition:transform .26s cubic-bezier(.34,1.56,.64,1);box-shadow:0 12px 40px rgba(0,0,0,.2)}
.nsm-overlay.nsm-visible .nsm-card{transform:translateY(0) scale(1)}
.nsm-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:22px;line-height:1;color:#94a3b8;cursor:pointer;padding:2px 7px;border-radius:6px;transition:background .15s,color .15s}
.nsm-close:hover{background:#f1f5f9;color:#1e293b}
.nsm-avatar-lg{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#1e40af 0%,#3b82f6 100%);color:white;font-size:26px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 16px rgba(30,64,175,.35)}
.nsm-name{text-align:center;font-size:17px;font-weight:700;color:#1e293b;margin-bottom:18px;letter-spacing:.2px}
.nsm-rows{display:flex;flex-direction:column;gap:9px;margin-bottom:16px}
.nsm-row{display:flex;gap:12px;align-items:flex-start}
.nsm-label{font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.6px;width:90px;flex-shrink:0;padding-top:2px}
.nsm-val{font-size:13px;color:#1e293b;font-weight:500;line-height:1.4}
.nsm-msg-box{border-top:1px solid #f1f5f9;padding-top:14px}
.nsm-msg-label{font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.6px;margin-bottom:7px}
.nsm-msg-body{font-size:13px;color:#334155;background:#f8fafc;border-radius:9px;padding:10px 13px;border:1px solid #e2e8f0;line-height:1.5;word-break:break-word}
</style>

<div class="nc-inner">
<div class="nc-header">
  <div>
    <div class="nc-brand-sub">CIMENTERIE DE SÉTIF — GICA</div>
    <div class="nc-brand-title">Dashboard RMQSE</div>
  </div>
  <div class="nc-header-right">
  </div>
</div>

<div class="nc-section-hdr rmqse">
  <span>Espace RMQSE</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="section-title">Calendrier de réception — FNC &amp; FAC</div>
  <div class="g2">

    <!-- Fiches reçues : FNC regroupées avec leurs FAC dans un seul conteneur -->
    <div class="nc-card" style="max-height:400px;overflow-y:auto">
      <div class="nc-card-title">Fiches reçues</div>
      <div class="nc-card-sub received-sub">Documents reçus aujourd'hui</div>
      <div class="received-list"></div>
    </div>

    <!-- Calendrier indépendant + sélecteur 2-clics -->
    <div style="display:flex;flex-direction:column;gap:8px">
      <div class="nc-card">
        <div class="nc-card-title" style="margin-bottom:8px">Calendrier</div>
        <div class="cal-wrap">
          <div class="cal-header-pick">
            <div class="cal-month-label" style="font-size:13px;font-weight:700;color:#1e293b">Chargement...</div>
            <span style="font-size:11px;color:#94a3b8">▼</span>
          </div>
          <div class="cal-picker" style="display:none;background:#f0f4ff;border:1px solid #c7d7f8;border-radius:8px;padding:8px;margin-bottom:8px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
              <button class="cal-btn cal-yr-prev">&#8249;</button>
              <span class="cal-picker-yr" style="font-size:13px;font-weight:700;color:#1e293b">2026</span>
              <button class="cal-btn cal-yr-next">&#8250;</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px">
              <div class="cal-pm" data-m="0">Jan</div><div class="cal-pm" data-m="1">Fév</div>
              <div class="cal-pm" data-m="2">Mar</div><div class="cal-pm" data-m="3">Avr</div>
              <div class="cal-pm" data-m="4">Mai</div><div class="cal-pm" data-m="5">Jun</div>
              <div class="cal-pm" data-m="6">Jul</div><div class="cal-pm" data-m="7">Aoû</div>
              <div class="cal-pm" data-m="8">Sep</div><div class="cal-pm" data-m="9">Oct</div>
              <div class="cal-pm" data-m="10">Nov</div><div class="cal-pm" data-m="11">Déc</div>
            </div>
          </div>
          <div class="cal-grid">
            <div class="cal-day-name">Lun</div><div class="cal-day-name">Mar</div><div class="cal-day-name">Mer</div><div class="cal-day-name">Jeu</div><div class="cal-day-name">Ven</div><div class="cal-day-name">Sam</div><div class="cal-day-name">Dim</div>
            <div class="cal-grid-body" style="display:contents"></div>
          </div>
          <div style="display:flex;gap:14px;margin-top:8px;justify-content:flex-end">
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#2196F3"></div>FNC</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#EF4444"></div>FAC</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:8px;height:8px;border-radius:50%;background:#7C3AED"></div>Plan</div>
          </div>
        </div>
      </div>

      <!-- Période : composant indépendant sous le calendrier -->
      <div style="background:white;border:1px solid #e2e8f0;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
        <span style="font-size:10px;font-weight:600;color:#64748b;white-space:nowrap;letter-spacing:.5px;text-transform:uppercase">Période stats</span>
        <div style="flex:1;height:1px;background:#e2e8f0"></div>
        <div class="period-btn">
          <div class="pb active" data-period="1m">1 mois</div>
          <div class="pb" data-period="6m">6 mois</div>
          <div class="pb" data-period="1y">1 an</div>
        </div>
      </div>
    </div>
  </div>

  <div class="g2" style="align-items:stretch">
    <div class="nc-card" style="display:flex;flex-direction:column">
      <div class="nc-card-title">Évolution FNC &amp; FAC — Créées par RMQSE</div>
      <canvas id="evoChart" style="flex:1;min-height:130px"></canvas>
      <div style="display:flex;gap:12px;margin-top:6px;justify-content:flex-end">
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#5B8CDB"></div>FNC</div>
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#C9443A"></div>FAC</div>
      </div>
    </div>

    <div class="g4">

      <!-- 1. AUDIT INTERNE — compteurs FNC + FAC cliquables -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#7C3AED"></div>
        <div class="nc-kpi-label">Audit Interne</div>
        <div style="display:flex;gap:6px;margin-top:6px">
          <div class="aud-btn btn-list"
               data-model="nc_management.nonconformity"
               data-domain='[["type_audit_interne","=",true]]'
               data-context='{"search_default_mes_fnc":0,"default_type_audit_interne":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FNC</div>
            <div class="aud-btn-val" style="color:#1d4ed8"><t t-esc="widget.stats.fnc_audit_interne"/></div>
          </div>
          <div class="aud-btn btn-list"
               data-model="nc_management.corrective_action"
               data-domain='[["fnc_id.type_audit_interne","=",true]]'
               data-context='{"search_default_fac_audit_interne":1}'>
            <div class="aud-btn-label">FAC</div>
            <div class="aud-btn-val" style="color:#991b1b"><t t-esc="widget.stats.fac_audit_interne"/></div>
          </div>
        </div>
      </div>

      <!-- 2. AUDIT EXTERNE — compteurs FNC + FAC cliquables -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#FF9800"></div>
        <div class="nc-kpi-label">Audit Externe</div>
        <div style="display:flex;gap:6px;margin-top:6px">
          <div class="aud-btn btn-list"
               data-model="nc_management.nonconformity"
               data-domain='[["type_audit_externe","=",true]]'
               data-context='{"search_default_mes_fnc":0,"default_type_audit_externe":true,"default_type_audit":true}'>
            <div class="aud-btn-label">FNC</div>
            <div class="aud-btn-val" style="color:#1d4ed8"><t t-esc="widget.stats.fnc_audit_externe"/></div>
          </div>
          <div class="aud-btn btn-list"
               data-model="nc_management.corrective_action"
               data-domain='[["fnc_id.type_audit_externe","=",true]]'
               data-context='{"search_default_fac_audit_externe":1}'>
            <div class="aud-btn-label">FAC</div>
            <div class="aud-btn-val" style="color:#991b1b"><t t-esc="widget.stats.fac_audit_externe"/></div>
          </div>
        </div>
      </div>

      <!-- 3. TOTAL FNC — Brouillon · Soumise · En cours · Validée -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#2196F3"></div>
        <div class="nc-kpi-label">Total FNC</div>
        <div class="nc-kpi-val" style="color:#1565C0"><t t-esc="widget.stats.fnc_total"/></div>
        <div class="nc-kpi-sub btn-list" data-model="nc_management.nonconformity" data-domain='[["state","=","validated"]]'>↳ Taux validation : <t t-esc="widget.stats.taux_cloture"/>%</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
          <span class="badge" style="background:#f1f5f9;color:#475569">Brouillon <t t-esc="widget.stats.fnc_brouillon"/></span>
          <span class="badge orange">Soumise <t t-esc="widget.stats.fnc_envoyes"/></span>
          <span class="badge blue">En cours <t t-esc="widget.stats.fnc_cours"/></span>
          <span class="badge" style="background:#d1fae5;color:#065f46">Validée <t t-esc="widget.stats.fnc_validated"/></span>
        </div>
      </div>

      <!-- 4. TOTAL FAC — Brouillon · Soumise · En cours · Validée · Clôturée -->
      <div class="nc-kpi">
        <div class="nc-kpi-top" style="background:#10B981"></div>
        <div class="nc-kpi-label">Total FAC</div>
        <div class="nc-kpi-val" style="color:#065F46"><t t-esc="widget.stats.fac_total"/></div>
        <div class="nc-kpi-txt">Taux efficacité : <t t-esc="widget.stats.taux_efficacite"/>%</div>
        <div class="nc-kpi-sub btn-list" data-model="nc_management.corrective_action" data-domain='[["state","=","closed"]]'>↳ Taux clôture : <t t-esc="widget.stats.taux_cloture_fac"/>%</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:6px">
          <span class="badge" style="background:#f1f5f9;color:#475569">Brouillon <t t-esc="widget.stats.fac_brouillon"/></span>
          <span class="badge" style="background:#fef9c3;color:#854d0e">Soumise <t t-esc="widget.stats.fac_submitted"/></span>
          <span class="badge orange">Soumise <t t-esc="widget.stats.fac_open"/></span>
          <span class="badge" style="background:#dbeafe;color:#1e40af">En cours <t t-esc="widget.stats.fac_verif"/></span>
          <span class="badge" style="background:#d1fae5;color:#065f46">Validée <t t-esc="widget.stats.fac_validated"/></span>
          <span class="badge green">Clôturée <t t-esc="widget.stats.fac_closed"/></span>
        </div>
      </div>

      <!-- 5. PLANS SMI REÇUS — pleine largeur -->
      <div class="nc-kpi" style="grid-column:1/-1;background:linear-gradient(135deg,#faf5ff 0%,#f5f3ff 100%);border-color:#e9d5ff">
        <div class="nc-kpi-top" style="background:linear-gradient(90deg,#6d28d9,#7c3aed)"></div>
        <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
          <div>
            <div class="nc-kpi-label">Plans SMI reçus</div>
            <div class="nc-kpi-val" style="color:#5B21B6"><t t-esc="widget.stats.plan_total"/></div>
          </div>
          <div style="height:36px;width:1px;background:#e9d5ff;flex-shrink:0"></div>
          <div style="flex:1;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <span class="badge" style="background:#f5f3ff;color:#6d28d9;border:1px solid #ddd6fe">En attente <t t-esc="widget.stats.plan_en_attente"/></span>
            <span class="badge" style="background:#f0fdf4;color:#059669;border:1px solid #bbf7d0">Intégrés <t t-esc="widget.stats.plan_integres"/></span>
          </div>
          <div class="nc-kpi-sub btn-list" data-model="nc_management.plan_action_smi" data-domain='[["sent_to_rmqse","=",true],["is_global","=",false]]' style="flex-shrink:0;margin:0">↳ Voir tous →</div>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="nc-section-hdr autres">
  <span>Autres services / Départements / Directions</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="g2" style="align-items:stretch">
    <div class="nc-card">
      <div class="nc-card-title">FNC &amp; FAC par direction</div>
      <div class="nc-card-sub">Barres groupées · Cliquer sur une barre FNC pour afficher les types</div>

      <!-- Total global toutes directions + départements + services -->
      <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;padding:8px 12px;background:#f0f9ff;border-radius:8px;border:1px solid #bae6fd">
        <div style="font-size:11px;font-weight:700;color:#0369a1;flex:1">Total global (tous espaces)</div>
        <span class="badge blue">FNC <t t-esc="widget.stats.global_fnc_total"/></span>
        <span class="badge red">FAC <t t-esc="widget.stats.global_fac_total"/></span>
      </div>

      <t t-foreach="widget.stats.direction_stats" t-as="dept">
        <div class="gc-row">
          <div class="gc-lbl" style="cursor:pointer" t-att-data-direction="dept.name" t-att-data-direction-id="dept.id"><t t-esc="dept.name"/></div>
          <div class="gc-bars">
            <div class="gc-bar-fnc dir-bar" t-att-data-direction="dept.name" t-att-data-direction-id="dept.id" data-kind="fnc" t-att-style="'width:'+dept.pct_fnc+'%'"></div>
            <div class="gc-bar-fac" t-att-style="'width:'+dept.pct_fac+'%'"></div>
          </div>
          <div class="gc-vals">
            <div class="gc-v"><t t-esc="dept.fnc_count"/></div>
            <div class="gc-v"><t t-esc="dept.fac_count"/></div>
          </div>
        </div>
      </t>

      <div class="gc-legend">
        <div class="gc-leg-item"><div class="gc-leg-dot" style="background:#2196F3"></div>FNC</div>
        <div class="gc-leg-item"><div class="gc-leg-dot" style="background:#EF4444"></div>FAC</div>
      </div>

      <!-- Filtres département / service -->
      <div class="dir-filter-zone" style="display:none;margin-top:10px;border-top:1px solid #f1f5f9;padding-top:8px">
        <div class="dir-filter-dept-row" style="margin-bottom:6px">
          <div style="font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Départements</div>
          <div class="dir-dept-pills" style="display:flex;flex-wrap:wrap;gap:5px"></div>
        </div>
        <div class="dir-filter-svc-row" style="display:none;margin-bottom:6px">
          <div style="font-size:10px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">Services</div>
          <div class="dir-svc-pills" style="display:flex;flex-wrap:wrap;gap:5px"></div>
        </div>
      </div>

      <div style="margin-top:10px;border-top:1px solid #f1f5f9;padding-top:10px">
        <div class="nc-card-sub dir-pie-scope">Types FNC liés à la barre sélectionnée</div>
        <div class="dir-pie-title">Sélectionnez une barre</div>
        <div class="dir-pie"></div>
        <div class="dir-pie-legend" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;justify-content:center;font-size:10px;color:#64748b"></div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:8px">
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#FF9800"></div>
        <div class="nc-card-title scope-dir-title">Par direction</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-dir-fnc" style="color:#1565C0"><t t-esc="widget.stats.scope_totals.direction.fnc"/></div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-dir-fac" style="color:#991B1B"><t t-esc="widget.stats.scope_totals.direction.fac"/></div></div>
        </div>
      </div>
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#10B981"></div>
        <div class="nc-card-title scope-dept-title">Par département</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-dept-fnc" style="color:#1565C0"><t t-esc="widget.stats.scope_totals.department.fnc"/></div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-dept-fac" style="color:#991B1B"><t t-esc="widget.stats.scope_totals.department.fac"/></div></div>
        </div>
      </div>
      <div class="nc-card" style="flex:1">
        <div class="nc-kpi-top" style="background:#7C3AED"></div>
        <div class="nc-card-title scope-svc-title">Par service</div>
        <div class="split-card">
          <div class="split-box"><div class="split-label">Total FNC</div><div class="split-val scope-svc-fnc" style="color:#1565C0"><t t-esc="widget.stats.scope_totals.service.fnc"/></div></div>
          <div class="split-box"><div class="split-label">Total FAC</div><div class="split-val scope-svc-fac" style="color:#991B1B"><t t-esc="widget.stats.scope_totals.service.fac"/></div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="nc-section-hdr globale">
  <span>Vue globale &amp; Alertes</span>
  <div class="nc-section-hdr-sep"></div>
</div>

<div>
  <div class="g2">
    <div class="nc-card">
      <div class="nc-card-title">Diagramme global FNC &amp; FAC</div>
      <div class="nc-card-sub">RMQSE + Tous les services combinés — par mois</div>
      <canvas id="globalChart" style="height:170px"></canvas>
      <div style="display:flex;gap:12px;margin-top:8px;justify-content:center">
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#5B8CDB"></div>FNC</div>
        <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:#64748b"><div style="width:10px;height:10px;border-radius:2px;background:#C9443A"></div>FAC</div>
      </div>
    </div>

    <div class="nc-card">
      <div class="nc-card-title">Alertes &amp; Notifications</div>
      <div class="nc-card-sub">FAC à clôturer · FNC en retard · &lt; 7 jours</div>

      <t t-foreach="widget.stats.fac_a_cloturer" t-as="fac">
        <t t-if="fac.days > 7">
          <div class="nc-alert">
            <div style="flex:1">
              <div style="font-size:12px;font-weight:600;color:#991b1b"><t t-esc="fac.name"/> — À clôturer</div>
              <div style="font-size:11px;color:#b91c1c;margin-top:2px"><t t-esc="fac.department"/> · Retard <t t-esc="fac.days"/> jours</div>
            </div>
            <span class="badge red">Urgent</span>
            <div class="btn-sm primary btn-open" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac.id">Ouvrir</div>
          </div>
        </t>
        <t t-if="fac.days > 3 and fac.days &lt;= 7">
          <div class="nc-alert orange">
            <div style="flex:1">
              <div style="font-size:12px;font-weight:600;color:#9a3412"><t t-esc="fac.name"/> — À clôturer</div>
              <div style="font-size:11px;color:#c2410c;margin-top:2px"><t t-esc="fac.department"/> · Dans <t t-esc="fac.days"/> jours</div>
            </div>
            <span class="badge orange">Bientôt</span>
            <div class="btn-sm btn-open" t-att-data-model="'nc_management.corrective_action'" t-att-data-id="fac.id">Ouvrir</div>
          </div>
        </t>
      </t>

      <t t-foreach="widget.stats.fnc_retard_list" t-as="fnc">
        <div class="nc-alert orange">
          <div style="flex:1">
            <div style="font-size:12px;font-weight:600;color:#9a3412"><t t-esc="fnc.name"/> — En retard</div>
            <div style="font-size:11px;color:#c2410c;margin-top:2px"><t t-esc="fnc.department"/> · <t t-esc="fnc.days"/> jours de retard</div>
          </div>
          <div class="btn-sm btn-open" t-att-data-model="'nc_management.nonconformity'" t-att-data-id="fnc.id">Ouvrir</div>
        </div>
      </t>
    </div>
  </div>
</div>

</div>
</div>
</t>

<t t-name="NcPlanSmi">
<div style="padding:24px;background:#f4f6f9;
            min-height:100vh;font-family:Arial,sans-serif;">

  <!-- Title -->
  <div style="background:white;border-radius:8px;padding:16px 20px;
              margin-bottom:20px;border-left:5px solid #2c3e50;
              display:flex; justify-content:space-between; align-items:center;">
    <div>
      <h3 style="margin:0;color:#2c3e50;font-size:16px;">
          Analyse de l'Efficacité — Plan SMI
      </h3>
      <p style="margin:4px 0 0;font-size:12px;color:#888;">
          Cimenterie de Sétif · Catégories liées aux FNC
      </p>
    </div>
    <button class="o_export_smi"
            style="background:#1e40af;color:white;border:1px solid #1e40af;
                   border-radius:6px;padding:5px 14px;font-size:12px;
                   font-weight:700;cursor:pointer;transition:background .15s;"
            onmouseover="this.style.background='#1d4ed8'"
            onmouseout="this.style.background='#1e40af'">
        <i class="fa fa-file-excel-o"></i> Export
    </button>
  </div>

  <!-- Table Analyse Efficacité Globale -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Analyse Efficacité Globale
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#2c3e50;color:white;">
          <th style="padding:10px 12px;border:1px solid #1a252f;
                     text-align:left;min-width:130px;"></th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Non efficace</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé 100%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisé plus 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Réalisée moins 50%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Taux Efficacité%</th>
          <th style="padding:10px 8px;border:1px solid #1a252f;
                     text-align:center;">Total</th>
        </tr>
      </thead>
      <tbody id="smi_body">
        <tr>
          <td colspan="8" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Graphe Taux d'efficacité par catégorie (%) -->
  <div style="background:white;border-radius:8px;padding:20px;
              margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux d'efficacité par catégorie (%)
    </h4>
    <div style="position:relative;overflow-x:auto;">
      <canvas id="smi_chart"></canvas>
    </div>
  </div>

  <!-- Table Taux réalisation processus -->
  <div style="background:white;border-radius:8px;padding:20px;
              box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <h4 style="margin:0 0 14px;color:#2c3e50;
               border-bottom:2px solid #2c3e50;padding-bottom:8px;">
        Taux de réalisation (revue processus)
    </h4>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#f8f9fa;">
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;">
              Processus
          </th>
          <th style="text-align:left;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:260px;">
              Taux de réalisation
          </th>
          <th style="text-align:center;padding:10px 12px;
                     border:1px solid #dee2e6;color:#2c3e50;
                     width:80px;">
              %
          </th>
        </tr>
      </thead>
      <tbody id="proc_body">
        <tr>
          <td colspan="3" style="text-align:center;padding:20px;
                                  color:#aaa;">
              Chargement...
          </td>
        </tr>
      </tbody>
    </table>
  </div>

</div>
</t>
</templates>
