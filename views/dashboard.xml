<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <template id="assets_backend" name="nc_management assets" inherit_id="web.assets_backend">
        <xpath expr="." position="inside">
            <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.min.js"/>
            <script type="text/javascript" src="/nc_management/static/src/js/dashboard.js"/>
        </xpath>
    </template>

    <record model="ir.actions.client" id="action_nc_dashboard">
        <field name="name">Dashboard Qualite</field>
        <field name="tag">nc_dashboard</field>
    </record>

    <menuitem
        name="Dashboard"
        id="nc_management.menu_dashboard"
        parent="nc_management.menu_root"
        action="action_nc_dashboard"
        groups="nc_management.group_nc_manager"
        sequence="1"/>

</data>
</odoo>
