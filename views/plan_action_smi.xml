<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ============================================================ -->
<!--  TREE — MES PLANS  (NC Utilisateur + Responsable Qualité)    -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_tree_mes_plans">
    <field name="name">nc_management.plan_action_smi.tree.mes_plans</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">10</field>
    <field name="arch" type="xml">
        <tree string="Mes Plans" import="false"
              decoration-danger="is_late == True">
            <field name="name"            string="Référence"/>
            <field name="direction_id"    string="Direction"/>
            <field name="nature"          string="Nature"/>
            <field name="responsable_id"  string="Responsable"/>
            <field name="avancement"      string="Avancement %"/>
            <field name="efficacite"      string="Efficacité"/>
            <field name="date_realisation" string="Date de réalisation"/>
            <field name="state"           string="État"/>
            <field name="is_integrated"   string="Intégré au plan d'amélioration"/>
            <field name="is_late"         invisible="1"/>
            <field name="submission_state" invisible="1"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  TREE — PLANS REÇUS  (Responsable Qualité uniquement)        -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_tree_recus">
    <field name="name">nc_management.plan_action_smi.tree.recus</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
        <tree string="Plans Reçus" import="false" create="false" delete="false" edit="false">
            <field name="name"/>
            <field name="direction_id"/>
            <field name="department_id"/>
            <field name="nature"/>
            <field name="sent_by"/>
            <field name="date_envoi"/>
            <field name="avancement"      string="Avancement %"/>
            <field name="global_plan_id"  string="Plan d'Amélioration"/>
            <field name="submission_state" invisible="1"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  TREE — PLAN D'AMÉLIORATION  (Responsable Qualité)           -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_tree_global">
    <field name="name">nc_management.plan_action_smi.tree.global</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
        <tree string="Plans d'Action d'Amélioration SMI" import="false"
              decoration-muted="submission_state == 'cloture'">
            <field name="name"/>
            <field name="mois_reception"    string="Date création"/>
            <field name="date_maj"          string="Dernière màj"/>
            <field name="nb_plans_integres" string="Nb Plans"/>
            <field name="avancement_global" string="Avancement Global %"/>
            <field name="taux_realisation"  string="Taux de réalisation %"/>
            <field name="taux_efficacite"   string="Taux d'efficacité %"/>
            <field name="etat_global"       string="État"/>
            <field name="submission_state"  invisible="1"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  FORM — PLAN D'ACTION NIVEAU 1 (nouveau cycle de vie SMI)   -->
<!--  Utilisé pour les plans liés à un Plan d'Amélioration        -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_form">
    <field name="name">nc_management.plan_action_smi.form</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">10</field>
    <field name="arch" type="xml">
        <form string="Plan d'Action Amélioration SMI">
            <header>
                <!-- Ancien système : Générer numéro + Envoyer -->
                <button name="action_generate_plan_number"
                        string="Générer le numéro du plan"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': ['|',
                            ('name', '!=', 'New'),
                            ('is_global', '=', True),
                            ('improvement_plan_id', '!=', False)]}"/>
                <button name="action_open_send_plan_wizard"
                        string="Envoyer"
                        type="object"
                        class="oe_highlight"
                        groups="nc_management.group_nc_utilisateur"
                        attrs="{'invisible': ['|',
                            ('name', '=', 'New'),
                            ('improvement_plan_id', '!=', False)]}"/>

                <!-- Nouveau cycle de vie : barre d'état étendue -->
                <field name="state" widget="statusbar"
                       statusbar_visible="en_cours,realise,cloture,draft,done"/>
            </header>
            <sheet>
                <!-- Champs techniques -->
                <field name="submission_state"     invisible="1"/>
                <field name="is_global"            invisible="1"/>
                <field name="sent_to_rmqse"        invisible="1"/>
                <field name="improvement_plan_id"  invisible="1"/>
                <field name="direct_global_plan_id" invisible="1"/>

                <!-- Bandeau : plan clôturé (définitif) -->
                <div class="alert alert-success"
                     attrs="{'invisible': [('state', '!=', 'cloture')]}">
                    <strong>&#10003; Plan clôturé — Action efficace.</strong>
                    Ce plan est définitivement clôturé. Aucune modification n'est possible.
                </div>

                <!-- Bandeau : en attente d'évaluation d'efficacité -->
                <div class="alert alert-warning"
                     attrs="{'invisible': [('state', '!=', 'realise')]}">
                    <strong>&#9654; Plan réalisé (avancement 100%).</strong>
                    Veuillez évaluer l'efficacité de l'action ci-dessous.
                </div>

                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <!-- Organisation -->
                <group string="Organisation">
                    <group>
                        <field name="direction_id"
                               attrs="{'readonly': ['|',
                                   ('state', '=', 'cloture'),
                                   ('submission_state', '!=', 'brouillon')]}"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="department_id"
                               attrs="{'invisible': [('direction_id', '=', False)],
                                       'readonly':  ['|',
                                           ('state', '=', 'cloture'),
                                           ('submission_state', '!=', 'brouillon')]}"
                               domain="[('scaek_level','=','departement'),('parent_id','=',direction_id)]"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="service_id"
                               attrs="{'invisible': [('department_id', '=', False)],
                                       'readonly':  ['|',
                                           ('state', '=', 'cloture'),
                                           ('submission_state', '!=', 'brouillon')]}"
                               domain="[('scaek_level','=','service'),('parent_id','=',department_id)]"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                    <group>
                        <field name="sent_by"
                               attrs="{'invisible': [('sent_to_rmqse', '=', False)]}"
                               readonly="1"/>
                        <field name="date_envoi"
                               attrs="{'invisible': [('sent_to_rmqse', '=', False)]}"
                               readonly="1"/>
                    </group>
                </group>

                <!-- Identification -->
                <group string="Identification">
                    <group>
                        <field name="nature"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                        <field name="fnc_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                    <group/>
                </group>

                <!-- Description -->
                <group string="Description / Objectif d'amélioration">
                    <field name="description" nolabel="1" colspan="2"
                           attrs="{'readonly': [('state', '=', 'cloture')]}"
                           placeholder="Décrivez la non-conformité ou l'objectif d'amélioration..."/>
                </group>

                <!-- Causes / Action -->
                <group>
                    <group string="Causes">
                        <field name="causes" nolabel="1"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"
                               placeholder="Analysez les causes..."/>
                    </group>
                    <group string="Action">
                        <field name="action" nolabel="1"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"
                               placeholder="Décrivez l'action corrective ou préventive..."/>
                    </group>
                </group>

                <!-- Ressources -->
                <group string="Ressources">
                    <group>
                        <field name="responsable_id"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="duree_estimee"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                    <group>
                        <field name="moyens"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                </group>

                <!-- Dates -->
                <group string="Dates">
                    <group>
                        <field name="date_prevue"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                        <field name="date_lancement"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                    <group>
                        <field name="date_realisation"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                        <field name="duree_reelle"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                </group>

                <!-- Avancement -->
                <group string="Avancement">
                    <group>
                        <field name="avancement"
                               attrs="{'readonly': [('state', '=', 'cloture')]}"
                               widget="progressbar"/>
                    </group>
                    <group/>
                </group>

                <!-- Critère d'Efficacité -->
                <group string="Critère d'Efficacité">
                    <field name="critere_efficacite" nolabel="1" colspan="2"
                           attrs="{'readonly': [('state', '=', 'cloture')]}"
                           placeholder="Définissez le critère pour juger l'efficacité..."/>
                </group>

                <!-- Résultat d'efficacité :
                     INVISIBLE si avancement < 100 (nouveau système)
                     ou si pas encore réalisé (état draft/en_cours) -->
                <group string="Évaluation d'Efficacité">
                    <group>
                        <field name="efficacite"
                               attrs="{'invisible': ['|',
                                   ('avancement', '&lt;', 100),
                                   ('state', 'in', ['en_cours', 'draft'])],
                                       'readonly': [('state', '=', 'cloture')]}"/>
                    </group>
                    <group>
                        <field name="remarque"
                               attrs="{'invisible': [('efficacite', '!=', 'non')],
                                       'readonly':  [('state', '=', 'cloture')]}"
                               placeholder="Si non efficace, précisez la raison et planifiez une nouvelle action..."/>
                    </group>
                </group>

            </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="activity_ids"         widget="mail_activity"/>
                <field name="message_ids"          widget="mail_thread"/>
            </div>
        </form>
    </field>
</record>

<!-- ============================================================ -->
<!--  FORM — PLAN D'ACTION D'AMÉLIORATION SMI                     -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_form_global">
    <field name="name">nc_management.plan_action_smi.form.global</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
        <form string="Plan d'Action d'Amélioration SMI">
            <header>
                <!-- Consolider : ouvre le wizard de sélection des plans -->
                <button name="action_consolider_tous"
                        string="Consolider"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('submission_state', '=', 'cloture')]}"/>
                <!-- Clôturer : crée automatiquement le plan suivant -->
                <button name="action_cloturer_plan"
                        string="Clôturer"
                        type="object"
                        confirm="Clôturer ce plan créera automatiquement un nouveau Plan d'Amélioration avec les plans récents. Continuer ?"
                        attrs="{'invisible': [('submission_state', '=', 'cloture')]}"
                        style="color: white; background-color: #d9534f;"/>
            </header>
            <sheet>
                <!-- Champs techniques requis par attrs -->
                <field name="nb_plans_integres" invisible="1"/>
                <field name="submission_state"  invisible="1"/>
                <field name="is_global"         invisible="1"/>

                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <!-- Bandeau plan clôturé -->
                <div class="alert alert-warning"
                     attrs="{'invisible': [('submission_state', '!=', 'cloture')]}">
                    <strong>Plan clôturé.</strong>
                    Un nouveau Plan d'Action d'Amélioration a été créé automatiquement.
                </div>

                <group string="Synthèse">
                    <group>
                        <field name="mois_reception"    string="Date de création"/>
                        <field name="date_maj"          string="Dernière mise à jour"
                               readonly="1"/>
                        <field name="nb_plans_integres" string="Plans intégrés"/>
                        <field name="avancement_global" widget="percentpie"/>
                    </group>
                    <group>
                        <field name="taux_realisation"  string="Taux de réalisation %"/>
                        <field name="taux_efficacite"   string="Taux d'efficacité %"/>
                    </group>
                </group>

                <notebook>
                    <page string="Plans intégrés">
                        <field name="child_plan_ids" readonly="1">
                            <tree string="Plans intégrés" import="false"
                                  decoration-success="state == 'done'"
                                  decoration-danger="is_late == True"
                                  decoration-muted="submission_state == 'integre'">
                                <field name="name"/>
                                <field name="direction_id"/>
                                <field name="department_id"/>
                                <field name="nature"/>
                                <field name="responsable_id"/>
                                <field name="date_prevue"/>
                                <field name="avancement"       string="Avancement %"/>
                                <field name="efficacite"/>
                                <field name="state"            string="Avancement"/>
                                <field name="submission_state" string="État"
                                       invisible="1"/>
                                <field name="is_late"          invisible="1"/>
                            </tree>
                        </field>
                    </page>
                </notebook>

            </sheet>
        </form>
    </field>
</record>

<!-- ============================================================ -->
<!--  SEARCH — MES PLANS                                           -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_search">
    <field name="name">nc_management.plan_action_smi.search</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">10</field>
    <field name="arch" type="xml">
        <search string="Rechercher Plan Action SMI">
            <field name="name"          string="Référence"/>
            <field name="direction_id"/>
            <field name="responsable_id"/>
            <field name="fnc_id"/>
            <separator/>
            <filter string="Mes Plans"    name="mes_plans"
                    domain="[('create_uid', '=', uid), ('is_global', '=', False)]"/>
            <filter string="Plans Reçus"  name="plans_recus"
                    domain="[('sent_to_rmqse', '=', True),
                             ('is_global', '=', False),
                             ('create_uid', '!=', uid)]"/>
            <filter string="En retard"    name="en_retard"
                    domain="[('date_prevue', '&lt;', context_today().strftime('%Y-%m-%d')),
                             ('state', '!=', 'verified')]"/>
            <separator/>
            <filter string="Brouillon"    name="f_brouillon"
                    domain="[('submission_state', '=', 'brouillon')]"/>
            <filter string="Soumis"       name="f_soumis"
                    domain="[('submission_state', '=', 'soumis')]"/>
            <filter string="Intégré"      name="f_integre"
                    domain="[('submission_state', '=', 'integre')]"/>
            <separator/>
            <filter string="En cours"     name="en_cours"
                    domain="[('state', '=', 'draft')]"/>
            <filter string="Réalisé"      name="realise"
                    domain="[('state', '=', 'done')]"/>
            <group expand="0" string="Grouper par">
                <filter string="Direction"   name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="Département" name="group_department"
                        context="{'group_by': 'department_id'}"/>
                <filter string="Nature"      name="group_nature"
                        context="{'group_by': 'nature'}"/>
                <filter string="État"        name="group_state"
                        context="{'group_by': 'submission_state'}"/>
                <filter string="Responsable" name="group_responsable"
                        context="{'group_by': 'responsable_id'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ============================================================ -->
<!--  SEARCH — PLANS REÇUS  (Responsable Qualité)                 -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_search_recus">
    <field name="name">nc_management.plan_action_smi.search.recus</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
        <search string="Plans Reçus">
            <field name="name"      string="Référence"/>
            <field name="direction_id"/>
            <field name="sent_by"   string="Envoyé par"/>
            <separator/>
            <filter string="Ce mois"     name="ce_mois"
                    domain="[('mois_reception', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
            <separator/>
            <filter string="En attente" name="en_attente"
                    domain="[('submission_state', '=', 'soumis')]"/>
            <filter string="Intégrés"   name="integres"
                    domain="[('submission_state', '=', 'integre')]"/>
            <filter string="Tous"       name="tous"
                    domain="[('sent_to_rmqse', '=', True)]"/>
            <group expand="1" string="Grouper par">
                <filter string="Direction"         name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="Département"       name="group_department"
                        context="{'group_by': 'department_id'}"/>
                <filter string="Mois de réception" name="group_mois"
                        context="{'group_by': 'mois_reception:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ============================================================ -->
<!--  GRAPH (camembert) + GRAPH (barres) + PIVOT                  -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_graph_state">
    <field name="name">nc_management.plan_action_smi.graph.state</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="arch" type="xml">
        <graph string="Répartition par état" type="pie">
            <field name="submission_state" type="row"/>
        </graph>
    </field>
</record>

<record model="ir.ui.view" id="view_plan_smi_graph_direction">
    <field name="name">nc_management.plan_action_smi.graph.direction</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="arch" type="xml">
        <graph string="Plans par Direction" type="bar">
            <field name="direction_id"     type="row"/>
            <field name="submission_state" type="col"/>
        </graph>
    </field>
</record>

<record model="ir.ui.view" id="view_plan_smi_pivot">
    <field name="name">nc_management.plan_action_smi.pivot</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="arch" type="xml">
        <pivot string="Analyse Plans SMI">
            <field name="direction_id"     type="row"/>
            <field name="submission_state" type="col"/>
        </pivot>
    </field>
</record>

<!-- ============================================================ -->
<!--  ACTIONS                                                      -->
<!-- ============================================================ -->

<!-- Mes Plans (NC Utilisateur + Responsable Qualité) -->
<record model="ir.actions.act_window" id="action_mes_plans_smi">
    <field name="name">Mes Plans SMI</field>
    <field name="res_model">nc_management.plan_action_smi</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('is_global', '=', False)]</field>
    <field name="context">{'search_default_mes_plans': 1, 'no_import': True}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('view_plan_smi_tree_mes_plans')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_plan_smi_form')})]"/>
</record>

<!-- Plans Reçus (Responsable Qualité uniquement)
     Pas de filtre sur submission_state : les plans restent visibles
     même après consolidation dans un Plan d'Amélioration -->
<record model="ir.actions.act_window" id="action_plans_recus_smi">
    <field name="name">Plans Reçus</field>
    <field name="res_model">nc_management.plan_action_smi</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('sent_to_rmqse', '=', True),
                          ('is_global', '=', False),
                          ('create_uid', '!=', uid)]</field>
    <field name="context">{'search_default_group_direction': 1, 'no_import': True}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('view_plan_smi_tree_recus')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_plan_smi_form')})]"/>
    <field name="search_view_id" ref="view_plan_smi_search_recus"/>
</record>

<!-- Plan d'Action d'Amélioration (Responsable Qualité uniquement) -->
<record model="ir.actions.act_window" id="action_plan_global_smi">
    <field name="name">Plan d'Action d'Amélioration SMI</field>
    <field name="res_model">nc_management.plan_action_smi</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('is_global', '=', True)]</field>
    <field name="context">{'no_import': True, 'default_is_global': True}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('view_plan_smi_tree_global')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_plan_smi_form_global')})]"/>
</record>

<!-- ============================================================ -->
<!--  TREE — LISTE DES ANALYSES (Plans clôturés)                  -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_tree_analyses">
    <field name="name">nc_management.plan_action_smi.tree.analyses</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">18</field>
    <field name="arch" type="xml">
        <tree string="Analyses d'Efficacité" import="false" create="false">
            <field name="name"              string="Plan d'Amélioration"/>
            <field name="mois_reception"    string="Période"/>
            <field name="date_maj"          string="Date de clôture"/>
            <field name="nb_plans_integres" string="Plans intégrés"/>
            <field name="avancement_global" string="Avancement global %"/>
            <field name="nb_realises"       string="Réalisés"/>
            <field name="nb_en_retard"      string="En retard"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  FORM — ANALYSE EFFICACITÉ (clic depuis la liste)            -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_plan_smi_form_analyse">
    <field name="name">nc_management.plan_action_smi.form.analyse</field>
    <field name="model">nc_management.plan_action_smi</field>
    <field name="priority">18</field>
    <field name="arch" type="xml">
        <form string="Analyse Efficacité Globale" edit="false">
            <sheet>
                <div class="oe_title">
                    <h2>Analyse Efficacité Globale</h2>
                    <h4 style="color:#888;">
                        <field name="name" readonly="1"/>
                    </h4>
                </div>

                <group>
                    <group>
                        <field name="mois_reception"    string="Période"         readonly="1"/>
                        <field name="date_maj"          string="Date de clôture" readonly="1"/>
                    </group>
                    <group>
                        <field name="nb_plans_integres" string="Plans intégrés"  readonly="1"/>
                        <field name="avancement_global" string="Avancement %"    readonly="1"/>
                    </group>
                </group>

                <field name="analyse_html" widget="html" readonly="1" nolabel="1"/>
            </sheet>
        </form>
    </field>
</record>

<!-- Analyse d'Efficacité — liste + formulaire (clic sur ligne ouvre l'analyse) -->
<record model="ir.actions.act_window" id="action_plan_smi_analyse_efficacite">
    <field name="name">Analyses d'Efficacité</field>
    <field name="res_model">nc_management.plan_action_smi</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('is_global', '=', True), ('submission_state', '=', 'cloture')]</field>
    <field name="context">{'no_import': True}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('view_plan_smi_tree_analyses')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_plan_smi_form_analyse')})]"/>
</record>

