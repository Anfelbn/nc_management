<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ============================================================ -->
<!--  VUE LISTE — Plans d'Amélioration SMI (niveau 2)            -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_smi_improvement_plan_tree">
    <field name="name">nc_management.smi_improvement_plan.tree</field>
    <field name="model">nc_management.smi_improvement_plan</field>
    <field name="arch" type="xml">
        <tree string="Plans d'Action d'Amélioration SMI" class="nc_list_tree smi_improvement_tree"
              import="false" create="false" delete="false"
              decoration-info="state == 'brouillon'"
              decoration-success="state == 'soumis'">
            <field name="name"             string="Référence"/>
            <field name="direction_id"     string="Direction"/>
            <field name="date_ouverture"   string="Date création"/>
            <field name="write_date"       string="Dernière màj"/>
            <field name="nb_plans"         string="Nb Plans"/>
            <field name="taux_avancement"  string="Avancement Global %"/>
            <field name="taux_realisation" string="Taux de réalisation %"/>
            <field name="taux_efficacite"  string="Taux d'efficacité %"/>
            <field name="state"            string="État"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUE LISTE — Plan d'Amélioration (NC Utilisateur)            -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_smi_improvement_plan_tree_user">
    <field name="name">nc_management.smi_improvement_plan.tree.user</field>
    <field name="model">nc_management.smi_improvement_plan</field>
    <field name="arch" type="xml">
        <tree string="Plan d'Action d'Amélioration" class="nc_list_tree smi_improvement_user_tree"
              import="false" delete="false"
              decoration-info="state == 'brouillon'"
              decoration-success="state == 'soumis'">
            <field name="name"            string="Référence"/>
            <field name="date_ouverture"  string="Date de création"/>
            <field name="write_date"      string="Dernière màj"/>
            <field name="nb_plans"        string="Nb Plans"/>
            <field name="taux_avancement" string="Avancement Global %"/>
            <field name="taux_realisation" string="Taux de réalisation %"/>
            <field name="taux_efficacite" string="Taux d'efficacité %"/>
            <field name="date_soumission" string="Date soumission"/>
            <field name="state"           invisible="1"/>
        </tree>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUE FORMULAIRE — Plan d'Amélioration SMI (niveau 2)        -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_smi_improvement_plan_form">
    <field name="name">nc_management.smi_improvement_plan.form</field>
    <field name="model">nc_management.smi_improvement_plan</field>
    <field name="arch" type="xml">
        <form string="Plan d'Action d'Amélioration SMI" delete="false">
            <header>
                <button name="action_consolider"
                        string="Consolider"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('date_consultation', '!=', False)]}"/>
                <button name="action_soumettre"
                        string="Envoyer"
                        type="object"
                        attrs="{'invisible': ['|',
                            ('state', '!=', 'brouillon'),
                            ('date_consultation', '!=', False)]}"
                        confirm="Envoyer ce plan à la Responsable Qualité ? Cette action est irréversible."/>
                <button name="action_open_consulter_version_wizard"
                        string="Consulter"
                        type="object"
                        attrs="{'invisible': [('date_consultation', '!=', False)]}"/>
                <button name="action_retour_actuel"
                        string="&#8592; Version actuelle"
                        type="object"
                        class="btn-warning"
                        attrs="{'invisible': [('date_consultation', '=', False)]}"/>
            </header>
            <sheet>
                <field name="date_consultation" invisible="1"/>
                <field name="state" invisible="1"/>

                <!-- Bandeau vue historique -->
                <div class="alert alert-warning"
                     attrs="{'invisible': [('date_consultation', '=', False)]}">
                    <strong>&#9888; Vue historique active.</strong>
                    Cliquez sur <em>« &#8592; Version actuelle »</em> pour revenir à la version en cours.
                </div>

                <!-- Bandeau plan envoyé -->
                <div class="alert alert-success"
                     attrs="{'invisible': [('state', '!=', 'soumis')]}">
                    <strong>Plan envoyé à la Responsable Qualité.</strong>
                    Les plans d'action sont maintenant visibles dans le Plan Global SMI.
                </div>

                <div style="text-align: center;">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <!-- Synthèse — même layout que la RMQSE -->
                <group>
                    <group>
                        <field name="date_ouverture"   string="Date de création"
                               attrs="{'readonly': [('state', '!=', 'brouillon')]}"/>
                        <field name="nb_plans"         string="Plans intégrés"/>
                        <field name="nb_realises"      string="Plans réalisés"/>
                        <field name="nb_en_cours"      string="Plans en cours"/>
                        <field name="nb_non_realises"  string="Plans non réalisés"/>
                    </group>
                    <group>
                        <field name="date_soumission"  string="Date d'envoi" readonly="1"
                               attrs="{'invisible': [('state', '=', 'brouillon')]}"/>
                        <field name="write_date"       string="Dernière mise à jour" readonly="1"/>
                        <field name="taux_avancement"  string="Taux d'avancement %"/>
                        <field name="taux_realisation" string="Taux de réalisation %"/>
                        <field name="taux_efficacite"  string="Taux d'efficacité %"/>
                    </group>
                </group>

                <!-- Vue historique HTML -->
                <div attrs="{'invisible': [('date_consultation', '=', False)]}">
                    <field name="historique_html" widget="html" readonly="1" nolabel="1"/>
                </div>

                <!-- Plans intégrés — masqués en vue historique -->
                <notebook attrs="{'invisible': [('date_consultation', '!=', False)]}">
                    <page string="Plans intégrés">
                        <field name="plan_ids"
                               attrs="{'readonly': [('date_consultation', '!=', False)]}"
                               context="{'default_improvement_plan_id': active_id}">
                            <tree string="Plans intégrés" import="false" create="false"
                                  class="smi_plan_tree"
                                  decoration-success="etat_avancement == 'realise'"
                                  decoration-warning="etat_avancement == 'en_cours'"
                                  decoration-danger="is_late == True">
                                <field name="nature"           string="Nature"/>
                                <field name="name"             invisible="1"/>
                                <field name="reference"        string="Référence"/>
                                <field name="responsable_id"   string="Responsable"
                                       options="{'no_create': True}"/>
                                <field name="date_realisation" string="Date de réalisation"/>
                                <field name="avancement"       string="Avancement %"
                                       widget="progressbar"/>
                                <field name="efficacite"       string="Efficacité"/>
                                <field name="etat_avancement"  string="État"/>
                                <field name="is_late"          invisible="1"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUE RECHERCHE — Plans d'Amélioration                        -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_smi_improvement_plan_search">
    <field name="name">nc_management.smi_improvement_plan.search</field>
    <field name="model">nc_management.smi_improvement_plan</field>
    <field name="arch" type="xml">
        <search string="Rechercher Plan d'Amélioration">
            <field name="name"         string="Référence"/>
            <field name="direction_id"/>
            <separator/>
            <filter string="Mes Plans" name="mes_plans"
                    domain="[('create_uid', '=', uid)]"/>
            <filter string="Brouillon"  name="brouillon"
                    domain="[('state', '=', 'brouillon')]"/>
            <filter string="Soumis"     name="soumis"
                    domain="[('state', '=', 'soumis')]"/>
            <group expand="1" string="Grouper par">
                <filter string="Direction"  name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="État"       name="group_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Mois"       name="group_mois"
                        context="{'group_by': 'date_soumission:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUE RECHERCHE — Plans Reçus (RMQSE)                         -->
<!-- ============================================================ -->
<record model="ir.ui.view" id="view_smi_improvement_plan_search_recus">
    <field name="name">nc_management.smi_improvement_plan.search.recus</field>
    <field name="model">nc_management.smi_improvement_plan</field>
    <field name="arch" type="xml">
        <search string="Rechercher Plans Reçus">
            <field name="name"         string="Référence"/>
            <field name="direction_id"/>
            <group expand="1" string="Grouper par">
                <filter string="Direction"  name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="Mois"       name="group_mois"
                        context="{'group_by': 'date_soumission:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ============================================================ -->
<!--  ACTIONS FENÊTRE                                              -->
<!-- ============================================================ -->

<!-- Action : Liste des plans d'amélioration du NC Utilisateur connecté
     (sélection d'un plan puis ouverture de sa fiche) -->
<record model="ir.actions.act_window" id="action_smi_improvement_plan_user_list">
    <field name="name">Plan d'Action d'Amélioration</field>
    <field name="res_model">nc_management.smi_improvement_plan</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('create_uid', '=', uid)]</field>
    <field name="context">{'no_import': True, 'no_export': True}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('view_smi_improvement_plan_tree_user')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_smi_improvement_plan_form')})]"/>
    <field name="search_view_id" ref="view_smi_improvement_plan_search"/>
</record>

<!-- Action : Plans Reçus RMQSE — PAA soumis par les directions -->
<record model="ir.actions.act_window"
        id="action_smi_improvement_plan_rmqse">
    <field name="name">Plans Reçus</field>
    <field name="res_model">nc_management.smi_improvement_plan</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('state', '=', 'soumis'), ('create_uid', '!=', uid)]</field>
    <field name="context">{'search_default_group_direction': 1}</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree',
                'view_id': ref('view_smi_improvement_plan_tree')}),
        (0, 0, {'view_mode': 'form',
                'view_id': ref('view_smi_improvement_plan_form')})]"/>
    <field name="search_view_id"
           ref="view_smi_improvement_plan_search_recus"/>
</record>


<!-- ============================================================ -->
<!--  ACTIONS LIÉES AU MODÈLE (Action ▼ dans le control panel)    -->
<!-- ============================================================ -->

<record id="action_server_print_improvement_plan" model="ir.actions.server">
    <field name="name">Imprimer</field>
    <field name="model_id" ref="model_nc_management_smi_improvement_plan"/>
    <field name="binding_model_id" ref="model_nc_management_smi_improvement_plan"/>
    <field name="state">code</field>
    <field name="code">
if records:
    action = env.ref('nc_management.action_report_smi_improvement_plan').report_action(records)
    </field>
</record>

<record id="action_server_delete_improvement_plan" model="ir.actions.server">
    <field name="name">Supprimer</field>
    <field name="model_id" ref="model_nc_management_smi_improvement_plan"/>
    <field name="binding_model_id" ref="model_nc_management_smi_improvement_plan"/>
    <field name="state">code</field>
    <field name="code">
if records:
    action = records[:1].action_supprimer_plan()
    </field>
</record>

<!-- ============================================================ -->
<!--  MENUS                                                        -->
<!-- ============================================================ -->

<!-- Sous-menu "Plans Reçus" RMQSE — PAA soumis par les directions (sequence 3) -->
<menuitem
    name="Plans Reçus"
    id="nc_management.menu_smi_improvement_plan_recus"
    parent="nc_management.menu_plan_smi_root"
    action="action_smi_improvement_plan_rmqse"
    groups="nc_management.group_responsable_qualite"
    sequence="3"/>

<!-- Sous-menu "Plan d'Action d'Amélioration" pour NC Utilisateur -->
<menuitem
    name="Plan d'Action d'Amélioration"
    id="nc_management.menu_smi_improvement_plan_user"
    parent="nc_management.menu_plan_smi_root"
    action="action_smi_improvement_plan_user_list"
    groups="nc_management.group_nc_utilisateur"
    sequence="5"/>

</data>
</odoo>
