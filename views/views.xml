<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ============================================================ -->
<!--  VUES FNC                                                     -->
<!-- ============================================================ -->

<record model="ir.actions.act_window" id="action_fnc_number_wizard">
    <field name="name">Générer Numéro FNC</field>
    <field name="res_model">nc_management.number_generator_wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

<!-- Vue Liste FNC -->
<record model="ir.ui.view" id="view_nonconformity_tree">
    <field name="name">nc_management.nonconformity.tree</field>
    <field name="model">nc_management.nonconformity</field>
    <field name="arch" type="xml">
        <tree string="Fiches Non-Conformité">
            <field name="name"/>
            <field name="date"/>
            <field name="direction_id"/>
            <field name="department_id"/>
            <field name="service_id"/>
            <field name="signale_par_id"/>
            <field name="assigned_to_id"/>
            <field name="state"/>
        </tree>
    </field>
</record>

<!-- Vue Formulaire FNC -->
<record model="ir.ui.view" id="view_nonconformity_form">
    <field name="name">nc_management.nonconformity.form</field>
    <field name="model">nc_management.nonconformity</field>
    <field name="arch" type="xml">
        <form string="Fiche de Non-Conformité">
            <header>
                <button name="action_open_number_wizard"
                        string="Générer Numéro FNC"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('name','!=','New')]}"/>
                <button name="action_open_send_wizard"
                        string="Envoyer"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': ['|', ('state','=','validated'), ('name','=','New')]}"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,submitted,in_progress,validated"/>
            </header>
            <sheet>

                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <!-- ── En-tête (Step 1) ─────────────────────── -->
                <group string="En-tête">
                    <group>
                        <field name="direction_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="department_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')],
                                       'invisible': [('direction_id','=',False)]}"
                               domain="[('scaek_level','=','departement'),('parent_id','=',direction_id)]"/>
                        <field name="service_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')],
                                       'invisible': [('department_id','=',False)]}"
                               domain="[('scaek_level','=','service'),('parent_id','=',department_id)]"/>
                        <field name="section_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')],
                                       'invisible': [('service_id','=',False)]}"
                               domain="[('scaek_level','=','section'),('parent_id','=',service_id)]"/>
                        <field name="equipe_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')],
                                       'invisible': [('section_id','=',False)]}"
                               domain="[('scaek_level','=','equipe'),('parent_id','=',section_id)]"/>
                    </group>
                    <group>
                        <field name="date"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                    </group>
                </group>

                <!-- ── Type de Non-Conformité (Step 1) ─────────── -->
                <group string="Type de Non-Conformité">
                    <group>
                        <field name="type_nc_produit"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_reclamation"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_sst"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_environnement"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_travaux"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                    </group>
                    <group>
                        <field name="type_audit_interne"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_audit_externe"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_achat"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_reception"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_dysfonctionnement"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_autre"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="type_autre_preciser"
                               attrs="{'invisible': [('type_autre','=',False)],
                                       'required':  [('type_autre','=',True)],
                                       'readonly':  [('state','!=','draft')]}"/>
                    </group>
                </group>

                <!-- ── Section 1 — Description (Step 1) ──────── -->
                <group string="1- Description de la non-conformité">
                    <field name="description" nolabel="1"
                           placeholder="Décrivez la non-conformité..."
                           attrs="{'readonly': [('state','!=','draft')]}"/>
                    <group>
                        <field name="signale_par_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="date_signalement"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                        <field name="fonction_visa"
                               attrs="{'readonly': [('state','!=','draft')]}"/>
                    </group>
                </group>

                <!-- ── Traitement (Step 2) ───────────────────── -->
                <group string="Traitement">
                    <group>
                        <field name="trait_reprise"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="trait_declassement"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="trait_retour_fourn"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                    </group>
                    <group>
                        <field name="trait_recyclage"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="trait_reparation"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="trait_autre"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="trait_autre_preciser"
                               attrs="{'invisible': [('trait_autre','=',False)],
                                       'required':  [('trait_autre','=',True)],
                                       'readonly':  [('state','not in',['submitted'])]}"/>
                    </group>
                </group>

                <!-- ── Section 2 — Action immédiate (Step 2) ─── -->
                <group string="2- Action immédiate">
                    <field name="action_immediate" nolabel="1"
                           placeholder="Décrivez l'action immédiate..."
                           attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                    <group>
                        <field name="realise_par_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                        <field name="date_realisation"
                               attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                    </group>
                </group>

                <!-- ── Section 3 — Analyse des causes (Step 2) ─ -->
                <group string="3- Analyse des causes">
                    <field name="analyse_causes" nolabel="1"
                           placeholder="Analysez les causes..."
                           attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                    <field name="impact"
                           placeholder="Impact : coût, incidence, risque..."
                           attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                </group>

                <!-- ── Liaison FAC / Responsable ───────────────  -->
                <group string="Fiche d'Action Corrective">
                    <field name="assigned_to_id"
                           options="{'no_create': True, 'no_create_edit': True}"
                           attrs="{'readonly': [('state','not in',['submitted'])]}"/>
                    <field name="can_access_fac" invisible="1"/>
                    <field name="fac_reference" readonly="1"
                           attrs="{'invisible': [('can_access_fac','=',False)]}"/>
                    <field name="fac_number_display" readonly="1"
                           attrs="{'invisible': [('can_access_fac','=',True)]}"/>
                </group>

                <!-- ── Validation hiérarchique ──────────────────  -->
                <group string="Validation hiérarchique">
                    <group>
                        <field name="superieur_id"
                               options="{'no_create': True, 'no_create_edit': True}"
                               attrs="{'readonly': [('state','not in',['in_progress','validated'])]}"/>
                        <field name="date_validation"
                               attrs="{'readonly': [('state','not in',['in_progress','validated'])]}"/>
                    </group>
                    <group>
                        <field name="signature"
                               attrs="{'readonly': [('state','not in',['in_progress'])]}"/>
                    </group>
                </group>

            </sheet>
        </form>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUES FAC                                                     -->
<!-- ============================================================ -->

<!-- Vue Liste FAC -->
<record model="ir.ui.view" id="view_corrective_action_tree">
    <field name="name">nc_management.corrective_action.tree</field>
    <field name="model">nc_management.corrective_action</field>
    <field name="arch" type="xml">
        <tree string="Fiches Action Corrective">
            <field name="name"/>
            <field name="date"/>
            <field name="direction_id"/>
            <field name="fnc_id"/>
            <field name="responsable_id"/>
            <field name="state"/>
        </tree>
    </field>
</record>

<!-- Vue Recherche FAC -->
<record model="ir.ui.view" id="view_corrective_action_search">
    <field name="name">nc_management.corrective_action.search</field>
    <field name="model">nc_management.corrective_action</field>
    <field name="arch" type="xml">
        <search string="Rechercher FAC">

            <field name="name"         string="N° FAC"/>
            <field name="fnc_id"       string="N° FNC"/>
            <field name="direction_id" string="Direction"
                   domain="[('scaek_level','=','direction')]"/>
            <field name="responsable_id" string="Responsable"/>

            <filter string="Mes FAC" name="mes_fac"
                    domain="[('responsable_id','=',uid)]"/>
            <filter string="FAC reçus" name="toutes_fac"
                    domain="[]"/>

            <separator/>

            <filter string="Brouillon"  name="etat_brouillon"
                    domain="[('state','=','draft')]"/>
            <filter string="Soumises"   name="etat_soumise"
                    domain="[('state','=','submitted')]"/>
            <filter string="En cours"   name="etat_en_cours"
                    domain="[('state','=','in_progress')]"/>
            <filter string="Validées"   name="etat_validee"
                    domain="[('state','=','validated')]"/>
            <filter string="Clôturées"  name="etat_closed"
                    domain="[('state','=','closed')]"/>

            <group expand="0" string="Regrouper par">
                <filter string="Direction"   name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="Responsable" name="group_responsable"
                        context="{'group_by': 'responsable_id'}"/>
                <filter string="Statut"      name="group_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Date"        name="group_date"
                        context="{'group_by': 'date:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- Vue Formulaire FAC -->
<record model="ir.ui.view" id="view_corrective_action_form">
    <field name="name">nc_management.corrective_action.form</field>
    <field name="model">nc_management.corrective_action</field>
    <field name="arch" type="xml">
        <form string="Fiche d'Action Corrective">
            <header>
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,submitted,in_progress,validated,closed"/>
            </header>
            <sheet>

                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <group string="En-tête">
                    <group>
                        <field name="direction_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="date"/>
                        <field name="responsable_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="fnc_id"/>
                        <field name="date_fnc"/>
                    </group>
                </group>

                <group string="1- Rappel de la Non-Conformité">
                    <field name="rappel_nc" nolabel="1"
                           placeholder="Rappel de la non-conformité..."/>
                </group>

                <group string="2- Analyse des causes de la non-conformité">
                    <field name="analyse_causes" nolabel="1"
                           placeholder="Analysez les causes..."/>
                    <group>
                        <field name="responsable_analyse_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="date_analyse"/>
                        <field name="visa_analyse"/>
                    </group>
                </group>

                <group string="3- Action(s) décidée(s)">
                    <field name="action_line_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="action_description"/>
                            <field name="date_prevue"/>
                            <field name="date_realisation"/>
                            <field name="responsable_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        </tree>
                    </field>
                    <group>
                        <field name="responsable_actions_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="date_actions"/>
                        <field name="visa_actions"/>
                    </group>
                </group>

                <group string="Action(s) efficace(s)">
                    <field name="actions_efficaces"/>
                    <field name="responsable_efficacite_id" options="{'no_create': True, 'no_create_edit': True}"/>
                </group>

                <group string="4- Approbation Responsable QSE">
                    <group>
                        <field name="qse_nom_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="qse_date"/>
                    </group>
                    <group>
                        <field name="qse_visa"/>
                    </group>
                </group>

                <group string="5- Vérification de(s) action(s) effectuée(s)">
                    <field name="verification_efficacite" nolabel="1"
                           placeholder="Vérification de l'efficacité de l'action..."/>
                    <field name="extension_possible"/>
                </group>

                <group string="Clôture">
                    <group>
                        <field name="cloture_par_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="date_cloture"/>
                    </group>
                    <group>
                        <field name="visa_cloture"/>
                    </group>
                </group>

            </sheet>
        </form>
    </field>
</record>

<!-- ============================================================ -->
<!--  VUE RECHERCHE FNC                                            -->
<!-- ============================================================ -->

<record model="ir.ui.view" id="view_nonconformity_search">
    <field name="name">nc_management.nonconformity.search</field>
    <field name="model">nc_management.nonconformity</field>
    <field name="arch" type="xml">
        <search string="Rechercher FNC">

            <!-- ── Champs de recherche rapide ──────────────────── -->
            <field name="name"          string="N° FNC"/>
            <field name="direction_id"  string="Direction"
                   domain="[('scaek_level','=','direction')]"/>
            <field name="department_id" string="Département"
                   domain="[('scaek_level','=','departement')]"/>
            <field name="service_id"    string="Service"
                   domain="[('scaek_level','=','service')]"/>
            <field name="signale_par_id"  string="Signalé par"/>
            <field name="assigned_to_id"  string="Responsable action"/>

            <!-- ── Origine ─────────────────────────────────────── -->
            <filter string="Mes FNC" name="mes_fnc"
                    domain="[('create_uid','=',uid)]"/>
            <filter string="FNC Reçues" name="fnc_recues"
                    domain="[('create_uid','!=',uid)]"/>

            <separator/>

            <!-- ── Type d'audit (reçus) ────────────────────────── -->
            <filter string="Audit Interne" name="audit_interne"
                    domain="[('type_audit_interne','=',True)]"/>
            <filter string="Audit Externe" name="audit_externe"
                    domain="[('type_audit_externe','=',True)]"/>

            <separator/>

            <!-- ── État ────────────────────────────────────────── -->
            <filter string="Brouillon"  name="etat_brouillon"
                    domain="[('state','=','draft')]"/>
            <filter string="Soumises"   name="etat_soumise"
                    domain="[('state','=','submitted')]"/>
            <filter string="En cours"   name="etat_en_cours"
                    domain="[('state','=','in_progress')]"/>
            <filter string="Validées"   name="etat_validee"
                    domain="[('state','=','validated')]"/>

            <separator/>

            <!-- ── Périmètre hiérarchique ──────────────────────── -->
            <filter string="Par Direction"   name="par_direction"
                    domain="[('direction_id','!=',False)]"/>
            <filter string="Par Département" name="par_departement"
                    domain="[('department_id','!=',False)]"/>
            <filter string="Par Service"     name="par_service"
                    domain="[('service_id','!=',False)]"/>

            <!-- ── Regrouper par ───────────────────────────────── -->
            <group expand="0" string="Regrouper par">
                <filter string="Direction"   name="group_direction"
                        context="{'group_by': 'direction_id'}"/>
                <filter string="Département" name="group_departement"
                        context="{'group_by': 'department_id'}"/>
                <filter string="Service"     name="group_service"
                        context="{'group_by': 'service_id'}"/>
                <filter string="Statut"      name="group_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Date"        name="group_date"
                        context="{'group_by': 'date:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ============================================================ -->
<!--  ACTIONS ET MENUS                                             -->
<!-- ============================================================ -->


<record model="ir.actions.act_window" id="action_nonconformity">
    <field name="name">Non-Conformités</field>
    <field name="res_model">nc_management.nonconformity</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_nonconformity_search"/>
    <field name="context">{'search_default_mes_fnc': 1, 'skip_fnc_validation': True}</field>
</record>

<record model="ir.actions.act_window" id="action_corrective">
    <field name="name">Actions Correctives</field>
    <field name="res_model">nc_management.corrective_action</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_corrective_action_search"/>
    <field name="context">{'search_default_mes_fac': 1}</field>
</record>

<menuitem name="NC Management"
          id="nc_management.menu_root"
          sequence="10"/>

<menuitem name="Non-Conformités"
          id="nc_management.menu_nonconformity"
          parent="nc_management.menu_root"
          action="action_nonconformity"
          sequence="20"/>

<menuitem name="Actions Correctives"
          id="nc_management.menu_corrective"
          parent="nc_management.menu_root"
          action="action_corrective"
          sequence="20"/>

<!-- ============================================================ -->
<!--  VUES REVISIONS                                               -->
<!-- ============================================================ -->

<record model="ir.ui.view" id="view_document_revision_tree">
    <field name="name">nc_management.document_revision.tree</field>
    <field name="model">nc_management.document_revision</field>
    <field name="arch" type="xml">
        <tree string="Historique des Révisions" import="false"
              decoration-success="etat == 'valable'"
              decoration-muted="etat == 'obsolete'">
            <field name="doc_type"/>
            <field name="revision_number_link" widget="html"/>
            <field name="revision_date"/>
            <field name="reference"/>
            <field name="description"/>
            <field name="etat"/>
        </tree>
    </field>
</record>

<record model="ir.ui.view" id="view_document_revision_form">
    <field name="name">nc_management.document_revision.form</field>
    <field name="model">nc_management.document_revision</field>
    <field name="arch" type="xml">
        <form string="Révision de Document">
            <sheet>
                <group>
                    <group>
                        <field name="doc_type"/>
                        <field name="revision_number"/>
                        <field name="revision_date"/>
                        <field name="reference"/>
                    </group>
                    <group>
                        <field name="etat" string="État"/>
                    </group>
                </group>
                <group string="Modification apportée">
                    <field name="description" nolabel="1"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record model="ir.actions.act_window" id="action_document_revision">
    <field name="name">Révision des documents</field>
    <field name="res_model">nc_management.document_revision</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem name="Configuration"
          id="nc_management.menu_config"
          parent="nc_management.menu_root"
          sequence="100"
          groups="nc_management.group_responsable_qualite"/>

<menuitem name="Révision des documents"
          id="nc_management.menu_revision"
          parent="nc_management.menu_root"
          action="action_document_revision"
          sequence="30"/>

<!-- ============================================================ -->
<!--  VUE CONFIGURATION DÉPARTEMENTS (niveaux hiérarchiques)      -->
<!-- ============================================================ -->

<record model="ir.ui.view" id="view_hr_department_scaek_form">
    <field name="name">hr.department.scaek.form</field>
    <field name="model">hr.department</field>
    <field name="inherit_id" ref="hr.view_department_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='manager_id']" position="after">
            <field name="scaek_level" string="Niveau hiérarchique"/>
            <field name="scaek_code"  string="Code"/>
        </xpath>
    </field>
</record>

<record model="ir.ui.view" id="view_hr_department_scaek_tree">
    <field name="name">hr.department.scaek.tree</field>
    <field name="model">hr.department</field>
    <field name="inherit_id" ref="hr.view_department_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//tree" position="inside">
            <field name="scaek_level" string="Niveau"/>
            <field name="scaek_code"  string="Code"/>
        </xpath>
    </field>
</record>


</data>
</odoo>
