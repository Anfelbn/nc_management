<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="view_consolidate_improvement_wizard_form" model="ir.ui.view">
    <field name="name">nc_management.consolidate_improvement_wizard.form</field>
    <field name="model">nc_management.consolidate_improvement_wizard</field>
    <field name="arch" type="xml">
        <form string="Consolider des plans d'action">
            <sheet>
                <field name="improvement_plan_id" invisible="1"/>
                <group>
                    <p class="oe_grey">
                        Cochez les plans à intégrer dans ce Plan d'Amélioration,
                        puis cliquez sur <strong>Consolider</strong>.
                        Seuls vos plans non encore intégrés sont affichés.
                    </p>
                </group>
                <field name="line_ids" nolabel="1"
                       options="{'create': false, 'delete': false}">
                    <tree editable="bottom" create="false" delete="false"
                          class="smi_plan_tree">
                        <field name="selected"       string="✓"/>
                        <field name="plan_id"        string="Référence"/>
                        <field name="nature"         string="Nature"/>
                        <field name="description"    string="Description"/>
                        <field name="responsable_id" string="Responsable"/>
                        <field name="date_prevue"    string="Date prévue"/>
                        <field name="avancement"     string="Avancement %"/>
                        <field name="state"          string="État"/>
                    </tree>
                </field>
            </sheet>
            <footer>
                <button name="action_open_new_plan"
                        string="Ajouter une Action d'Amélioration"
                        type="object"/>
                <button name="action_consolidate"
                        string="Consolider"
                        type="object"
                        class="oe_highlight"/>
                <button string="Annuler" class="oe_link" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="action_consolidate_improvement_wizard" model="ir.actions.act_window">
    <field name="name">Consolider des plans d'action</field>
    <field name="res_model">nc_management.consolidate_improvement_wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

</data>
</odoo>
