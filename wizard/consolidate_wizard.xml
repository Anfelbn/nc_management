<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="view_consolidate_wizard_form" model="ir.ui.view">
    <field name="name">nc_management.consolidate_wizard.form</field>
    <field name="model">nc_management.consolidate_wizard</field>
    <field name="arch" type="xml">
        <form string="Consolider des Plans Reçus">
            <sheet>
                <field name="global_plan_id" invisible="1"/>
                <field name="line_ids" nolabel="1">
                    <tree editable="bottom" create="false" delete="false"
                          class="smi_plan_tree">
                        <field name="selected"          string="✓"/>
                        <field name="improvement_plan_id" string="Référence"/>
                        <field name="direction_id"      string="Direction"/>
                        <field name="date_ouverture"    string="Date création"/>
                        <field name="nb_plans"          string="Nb Plans"/>
                        <field name="taux_avancement"   string="Avancement Global %"/>
                        <field name="taux_realisation"  string="Taux de réalisation %"/>
                        <field name="taux_efficacite"   string="Taux d'efficacité %"/>
                        <field name="state"             string="État"/>
                    </tree>
                </field>
            </sheet>
            <footer>
                <button name="action_open_new_plan"
                        string="Ajouter Action d'Amélioration"
                        type="object"/>
                <button name="action_consolidate"
                        string="Consolider"
                        type="object"
                        class="oe_highlight"/>
                <button string="Annuler" class="oe_link" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="action_consolidate_wizard" model="ir.actions.act_window">
    <field name="name">Consolider des plans d'action d'améliorations</field>
    <field name="res_model">nc_management.consolidate_wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

</data>
</odoo>
