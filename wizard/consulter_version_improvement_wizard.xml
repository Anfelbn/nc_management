<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="view_consulter_version_improvement_wizard_form" model="ir.ui.view">
    <field name="name">nc_management.consulter_version_improvement_wizard.form</field>
    <field name="model">nc_management.consulter_version_improvement_wizard</field>
    <field name="arch" type="xml">
        <form string="Consulter une version passée">
            <sheet>
                <field name="improvement_plan_id" invisible="1"/>
                <group>
                    <field name="date_consultation" string="Date à consulter" required="1"/>
                </group>
            </sheet>
            <footer>
                <button name="action_consulter"
                        string="Voir cette version"
                        type="object"
                        class="oe_highlight"/>
                <button string="Annuler" class="oe_link" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

</data>
</odoo>
