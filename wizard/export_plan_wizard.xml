<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_export_plan_wizard_form" model="ir.ui.view">
        <field name="name">nc_management.export_plan_wizard.form</field>
        <field name="model">nc_management.export_plan_wizard</field>
        <field name="arch" type="xml">
            <form string="Exporter le Plan d'Action">
                <p class="oe_grey" attrs="{'invisible': [('excel_file', '!=', False)]}">
                    Cliquez sur Exporter pour générer le fichier Excel du Plan d'Action SMI.
                </p>
                <group attrs="{'invisible': [('excel_file', '=', False)]}">
                    <field name="file_name" invisible="1"/>
                    <field name="excel_file" filename="file_name"/>
                </group>
                <footer>
                    <button name="action_export" string="Exporter" type="object" class="btn-primary" attrs="{'invisible': [('excel_file', '!=', False)]}"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_export_plan_wizard" model="ir.actions.act_window">
        <field name="name">Exporter Plan Action SMI</field>
        <field name="res_model">nc_management.export_plan_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <act_window id="launch_export_plan_wizard"
                name="Export"
                src_model="nc_management.plan_action_smi"
                res_model="nc_management.export_plan_wizard"
                view_mode="form"
                target="new"
                key2="client_action_multi"/>
</odoo>
